---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
---

<Layout
  title="Page not found — Vermietler"
  description="The page you're looking for doesn't exist."
>
  <Navbar lang="en" />

  <main class="flex min-h-[70vh] items-center justify-center px-6 pt-24">
    <div class="text-center">
      <p class="text-sm font-semibold text-brand-500">404</p>
      <h1 class="mt-2 font-display text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">Page not found</h1>
      <p class="mt-4 text-base text-gray-500">The page you're looking for doesn't exist or has been moved.</p>
      <div class="mt-8 flex items-center justify-center gap-4">
        <a href="/" class="rounded-full bg-brand-500 px-6 py-2.5 text-sm font-semibold text-white shadow-xs transition hover:bg-brand-600">Go home</a>
        <a href="/blog" class="text-sm font-semibold text-gray-700 transition hover:text-gray-900">Blog</a>
      </div>
    </div>
  </main>
</Layout>
