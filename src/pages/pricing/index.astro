---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Pricing from "../../components/Pricing.astro";
import Footer from "../../components/Footer.astro";

const faqs = [
  {
    q: "Is the free tier really free forever?",
    a: "Yes. One rental unit is free forever, no credit card required and no time limit. It includes every feature except bank-account connection — operating cost statements (Nebenkostenabrechnung), tenant portal, expense tracking, document storage, tax reports, and more all work on the free tier."
  },
  {
    q: "How does per-unit billing actually work?",
    a: "Stripe Subscription quantity = max(1, total units − 1). Your first unit is always free. Add a 2nd unit → €10/month. Add a 10th → €90/month (9 billable seats). Remove a unit → quantity adjusts down automatically on the next invoice with prorated credit."
  },
  {
    q: "What if I only have one unit but want bank connection?",
    a: "We call that Single Plus: a single-unit landlord subscribes for €10/month to unlock automatic bank reconciliation. Same price as adding a second unit, no extra plan to manage. Cancel anytime."
  },
  {
    q: "Is the €10 with or without VAT?",
    a: "VAT inclusive. The €10 you see is the €10 you pay. No surprises at checkout."
  },
  {
    q: "Can I cancel at any time?",
    a: "Yes. Cancel from your billing page or the Stripe customer portal. Your subscription remains active until the end of the current billing period, then your account reverts to the free tier (1 unit, no bank connection). Your data is preserved."
  },
  {
    q: "Do you offer refunds?",
    a: "Yes — within 14 days of your first payment, no questions asked. Just contact support and we'll process the refund to your original payment method."
  },
  {
    q: "What happens to existing units if I cancel?",
    a: "Nothing. Units, properties, leases, documents, and history all stay intact. You just can't add more units beyond the first free one, and bank connection is disabled, until you resubscribe."
  },
  {
    q: "Is my data secure and DSGVO-compliant?",
    a: "Yes. All data is hosted in Germany, encrypted at rest and in transit, and processed in full compliance with the DSGVO. You can export or delete your data at any time."
  },
  {
    q: "Do I need to install anything?",
    a: "No. Vermietler is a fully cloud-based web application. It works in any modern browser on desktop, tablet, or mobile — no downloads, no updates, no IT setup."
  },
];
---

<Layout
  title="Pricing | Vermietler"
  description="Per-unit pricing for private landlords. First unit free forever, €10/month per additional unit (VAT included). No annual lock-in, no credit card to get started."
  keywords="vermietler pricing, property management software germany, landlord app price, immobilienverwaltung preise, vermieter software kosten, per unit pricing"
  alternateEn="/pricing"
  alternateDe="/de/preise"
>
  <Navbar lang="en" />

  <main class="bg-white pt-24">
    <Pricing lang="en" />

    <!-- Pay-per-use add-ons -->
    <section class="bg-gray-50 py-16">
      <div class="mx-auto max-w-4xl px-6">
        <h2 class="text-center font-display text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">
          Pay-per-use add-ons
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-center text-base text-gray-500">
          Available on every account, free or subscribed. Only pay for what you use.
        </p>
        <div class="mx-auto mt-10 max-w-sm">
          <div class="rounded-2xl border border-gray-200 bg-white p-6 text-center shadow-xs">
            <p class="text-xs font-semibold uppercase tracking-wider text-gray-400">Letter dispatch</p>
            <p class="mt-2 font-display text-3xl font-bold text-gray-900">€1.80</p>
            <p class="mt-1 text-sm text-gray-500">per letter (via Pingen)</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-white py-16">
      <div class="mx-auto max-w-3xl px-6">
        <h2 class="text-center font-display text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">
          Frequently Asked Questions
        </h2>
        <div class="mt-10 divide-y divide-gray-200">
          {faqs.map((faq) => (
            <details class="group py-5">
              <summary class="flex cursor-pointer items-center justify-between text-base font-semibold text-gray-900 [&::-webkit-details-marker]:hidden">
                <h3>{faq.q}</h3>
                <svg class="h-5 w-5 shrink-0 text-gray-400 transition group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-gray-600">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer lang="en" />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    name: "Vermietler",
    description: "Property management software for private landlords with per-unit pricing",
    brand: { "@type": "Brand", name: "Vermietler" },
    offers: [
      {
        "@type": "Offer",
        name: "Free tier",
        price: "0",
        priceCurrency: "EUR",
        description: "Free forever for a single rental unit. No card required.",
      },
      {
        "@type": "Offer",
        name: "Per-unit subscription",
        price: "10",
        priceCurrency: "EUR",
        priceSpecification: {
          "@type": "UnitPriceSpecification",
          price: "10",
          priceCurrency: "EUR",
          unitText: "unit per month",
          valueAddedTaxIncluded: true,
        },
        description: "€10/month per additional unit beyond the first. VAT inclusive.",
      },
    ],
  })} />
</Layout>
