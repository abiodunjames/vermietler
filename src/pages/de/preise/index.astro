---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import Pricing from "../../../components/Pricing.astro";
import Footer from "../../../components/Footer.astro";

const faqs = [
  {
    q: "Ist die kostenlose Stufe wirklich für immer kostenlos?",
    a: "Ja. Eine Mieteinheit ist dauerhaft kostenlos, ohne Kreditkarte und ohne zeitliche Begrenzung. Alle Funktionen außer der Bankverbindung sind enthalten — Nebenkostenabrechnung, Mieterportal, Ausgabenverfolgung, Dokumentenspeicher, Steuerberichte und vieles mehr funktionieren auf der kostenlosen Stufe."
  },
  {
    q: "Wie funktioniert die Abrechnung pro Einheit?",
    a: "Stripe-Abonnement-Menge = max(1, Einheiten gesamt − 1). Ihre erste Einheit ist immer kostenlos. 2. Einheit → 10 €/Monat. 10. Einheit → 90 €/Monat (9 kostenpflichtige Plätze). Bei Entfernen einer Einheit wird die Menge automatisch angepasst und auf der nächsten Rechnung anteilig gutgeschrieben."
  },
  {
    q: "Was, wenn ich nur eine Einheit habe, aber die Bankverbindung möchte?",
    a: "Wir nennen das „Single Plus“: ein Vermieter mit einer Einheit abonniert für 10 €/Monat und schaltet damit den automatischen Bankabgleich frei. Gleicher Preis wie eine zweite Einheit, kein zusätzlicher Tarif zu verwalten. Jederzeit kündbar."
  },
  {
    q: "Sind die 10 € inkl. oder zzgl. MwSt.?",
    a: "Inklusive MwSt. Die 10 €, die Sie sehen, sind die 10 €, die Sie zahlen. Keine Überraschungen beim Bezahlen."
  },
  {
    q: "Kann ich jederzeit kündigen?",
    a: "Ja. Kündigen Sie über die Abrechnungsseite oder das Stripe-Kundenportal. Ihr Abonnement bleibt bis zum Ende des aktuellen Abrechnungszeitraums aktiv, danach wird Ihr Konto auf die kostenlose Stufe zurückgesetzt (1 Einheit, keine Bankverbindung). Ihre Daten bleiben erhalten."
  },
  {
    q: "Bieten Sie Rückerstattungen an?",
    a: "Ja — innerhalb von 14 Tagen nach Ihrer ersten Zahlung, ohne Wenn und Aber. Kontaktieren Sie einfach den Support, und wir erstatten den Betrag auf Ihr ursprüngliches Zahlungsmittel zurück."
  },
  {
    q: "Was passiert mit bestehenden Einheiten, wenn ich kündige?",
    a: "Nichts. Einheiten, Immobilien, Mietverträge, Dokumente und Verlauf bleiben vollständig erhalten. Sie können lediglich keine weiteren Einheiten über die erste kostenlose hinaus hinzufügen, und die Bankverbindung ist deaktiviert, bis Sie wieder abonnieren."
  },
  {
    q: "Sind meine Daten sicher und DSGVO-konform?",
    a: "Ja. Alle Daten werden in Deutschland gehostet, sind im Ruhezustand und während der Übertragung verschlüsselt und werden vollständig DSGVO-konform verarbeitet. Sie können Ihre Daten jederzeit exportieren oder löschen."
  },
  {
    q: "Muss ich etwas installieren?",
    a: "Nein. Vermietler ist eine vollständig cloud-basierte Webanwendung. Sie funktioniert in jedem modernen Browser auf Desktop, Tablet oder Mobilgerät — keine Downloads, keine Updates, keine IT-Einrichtung."
  },
];
---

<Layout
  title="Preise | Vermietler"
  description="Preise pro Einheit für private Vermieter. Erste Einheit dauerhaft kostenlos, 10 €/Monat je weitere Einheit (inkl. MwSt.). Keine jährliche Bindung, keine Kreditkarte für den Einstieg."
  keywords="vermietler preise, immobilienverwaltung software preise, vermieter app kosten, hausverwaltungssoftware preis, pro einheit abrechnung"
  lang="de"
  alternateEn="/pricing"
  alternateDe="/de/preise"
>
  <Navbar lang="de" />

  <main class="bg-white pt-24">
    <Pricing lang="de" />

    <!-- Pay-per-use add-ons -->
    <section class="bg-gray-50 py-16">
      <div class="mx-auto max-w-4xl px-6">
        <h2 class="text-center font-display text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">
          Nutzungsbasierte Zusatzleistungen
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-center text-base text-gray-500">
          Verfügbar auf jedem Konto, kostenlos oder abonniert. Sie zahlen nur, was Sie tatsächlich nutzen.
        </p>
        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          <div class="rounded-2xl border border-gray-200 bg-white p-6 text-center shadow-xs">
            <p class="text-xs font-semibold uppercase tracking-wider text-gray-400">Briefversand</p>
            <p class="mt-2 font-display text-3xl font-bold text-gray-900">1,80 €</p>
            <p class="mt-1 text-sm text-gray-500">pro Brief (über Pingen)</p>
          </div>
          <div class="rounded-2xl border border-gray-200 bg-white p-6 text-center shadow-xs">
            <p class="text-xs font-semibold uppercase tracking-wider text-gray-400">Zusatz-OCR</p>
            <p class="mt-2 font-display text-3xl font-bold text-gray-900">2,00 €</p>
            <p class="mt-1 text-sm text-gray-500">Block à 50 Belege</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-white py-16">
      <div class="mx-auto max-w-3xl px-6">
        <h2 class="text-center font-display text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">
          Häufig gestellte Fragen
        </h2>
        <div class="mt-10 divide-y divide-gray-200">
          {faqs.map((faq) => (
            <details class="group py-5">
              <summary class="flex cursor-pointer items-center justify-between text-base font-semibold text-gray-900 [&::-webkit-details-marker]:hidden">
                <h3>{faq.q}</h3>
                <svg class="h-5 w-5 shrink-0 text-gray-400 transition group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-gray-600">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer lang="de" />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    name: "Vermietler",
    description: "Immobilienverwaltungssoftware für deutsche Vermieter mit Abrechnung pro Einheit",
    brand: { "@type": "Brand", name: "Vermietler" },
    offers: [
      {
        "@type": "Offer",
        name: "Kostenlose Stufe",
        price: "0",
        priceCurrency: "EUR",
        description: "Dauerhaft kostenlos für eine Mieteinheit. Keine Karte erforderlich.",
      },
      {
        "@type": "Offer",
        name: "Abonnement pro Einheit",
        price: "10",
        priceCurrency: "EUR",
        priceSpecification: {
          "@type": "UnitPriceSpecification",
          price: "10",
          priceCurrency: "EUR",
          unitText: "Einheit pro Monat",
          valueAddedTaxIncluded: true,
        },
        description: "10 €/Monat je weitere Einheit über die erste hinaus. Inkl. MwSt.",
      },
    ],
  })} />
</Layout>
