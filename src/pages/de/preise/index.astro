---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import Pricing from "../../../components/Pricing.astro";
import Footer from "../../../components/Footer.astro";

const faqs = [
  {
    q: "Ist der Free-Plan wirklich für immer kostenlos?",
    a: "Ja. Der Free-Plan (Starter) hat keine zeitliche Begrenzung, erfordert keine Kreditkarte und enthält keine versteckten Gebühren. Er ist so konzipiert, dass er den Bedarf eines Vermieters mit einer Einheit vollständig abdeckt — Banking, Ausgaben, Cashflow-Tracking und eine jährliche Nebenkostenabrechnung."
  },
  {
    q: "Was passiert, wenn ich ein Limit im Free-Plan erreiche?",
    a: "Sie sehen eine klare Meldung in der App, welches Limit erreicht wurde, mit einer Ein-Klick-Upgrade-Option. Ihre vorhandenen Daten werden nie gelöscht — Sie können nur nichts mehr hinzufügen, bis Sie upgraden oder Einträge entfernen."
  },
  {
    q: "Kann ich mein Plus-Abo jederzeit kündigen?",
    a: "Ja. Sie können direkt aus dem Kundenportal kündigen. Ihre Plus-Funktionen bleiben bis zum Ende des aktuellen Abrechnungszeitraums aktiv, danach wird Ihr Konto auf Free zurückgesetzt. Ihre Daten bleiben erhalten."
  },
  {
    q: "Bieten Sie Rückerstattungen an?",
    a: "Ja — innerhalb von 14 Tagen nach Ihrer ersten Zahlung, ohne Wenn und Aber. Kontaktieren Sie einfach den Support, und wir erstatten den Betrag auf Ihr ursprüngliches Zahlungsmittel zurück."
  },
  {
    q: "Was ist der Unterschied zwischen monatlicher und jährlicher Abrechnung?",
    a: "Bei jährlicher Abrechnung sparen Sie etwa 30%. Plus kostet 4,90 €/Monat bei jährlicher Zahlung (58,80 €/Jahr) im Vergleich zu 6,90 €/Monat bei monatlicher Abrechnung. Sie können jederzeit über das Kundenportal zwischen den Abrechnungszyklen wechseln."
  },
  {
    q: "Wird es teurere Pläne (Pro, Business) geben?",
    a: "Wir haben Pro- und Business-Tarife für die Zukunft geplant, gerichtet an Vermieter mit 50+ Einheiten und Hausverwaltungen. Sie werden Funktionen wie Team-Rollen, Audit-Logs, geplanten Bank-Sync, Massennachrichten und API-Zugang bieten. Wir starten sie, wenn klare Nachfrage von Nutzern besteht, die Plus-Limits erreichen."
  },
  {
    q: "Sind meine Daten sicher und DSGVO-konform?",
    a: "Ja. Alle Daten werden in Deutschland gehostet, sind im Ruhezustand und während der Übertragung verschlüsselt und werden vollständig DSGVO-konform verarbeitet. Sie können Ihre Daten jederzeit exportieren oder löschen."
  },
  {
    q: "Muss ich etwas installieren?",
    a: "Nein. Vermietler ist eine vollständig cloud-basierte Webanwendung. Sie funktioniert in jedem modernen Browser auf Desktop, Tablet oder Mobilgerät — keine Downloads, keine Updates, keine IT-Einrichtung."
  },
];
---

<Layout
  title="Preise — Vermietler | Immobilienverwaltung für deutsche Vermieter"
  description="Einfache, transparente Preise für deutsche Vermieter. Kostenlos für Vermieter mit einer Einheit, 4,90 €/Monat für wachsende Portfolios. Keine Kreditkarte erforderlich, DSGVO-konform."
  keywords="vermietler preise, immobilienverwaltung software preise, vermieter app kosten, hausverwaltungssoftware preis"
  lang="de"
  alternateEn="/pricing"
  alternateDe="/de/preise"
>
  <Navbar lang="de" />

  <main class="bg-white pt-24">
    <Pricing lang="de" />

    <!-- Comparison context -->
    <section class="bg-white py-16">
      <div class="mx-auto max-w-4xl px-6">
        <h2 class="text-center font-display text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">
          Das beste Preis-Leistungs-Verhältnis für deutsche Vermieter
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-center text-base text-gray-500">
          Vermietler bietet mehr Funktionen zu einem niedrigeren Preis als jedes vergleichbare deutsche Tool.
        </p>

        <div class="mt-10 overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-xs">
          <table class="w-full text-left text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-4 font-semibold text-gray-700">Tool</th>
                <th class="px-6 py-4 font-semibold text-gray-700">Free-Tier</th>
                <th class="px-6 py-4 font-semibold text-gray-700">Bezahlplan</th>
                <th class="px-6 py-4 font-semibold text-gray-700">Kosten pro Einheit</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <tr class="bg-brand-50/40">
                <td class="px-6 py-4 font-semibold text-brand-700">Vermietler Plus</td>
                <td class="px-6 py-4 text-gray-700">1 Einheit</td>
                <td class="px-6 py-4 text-gray-700">4,90 €/Mo (10 Einheiten)</td>
                <td class="px-6 py-4 font-semibold text-brand-600">0,49 €</td>
              </tr>
              <tr>
                <td class="px-6 py-4 text-gray-700">objego</td>
                <td class="px-6 py-4 text-gray-500">1 Einheit</td>
                <td class="px-6 py-4 text-gray-500">4,90–11,90 €/Mo</td>
                <td class="px-6 py-4 text-gray-500">1–2 €</td>
              </tr>
              <tr>
                <td class="px-6 py-4 text-gray-700">Vermietet.de</td>
                <td class="px-6 py-4 text-gray-500">Begrenzt</td>
                <td class="px-6 py-4 text-gray-500">7,90–9,90 €/Mo</td>
                <td class="px-6 py-4 text-gray-500">1–2 €</td>
              </tr>
              <tr>
                <td class="px-6 py-4 text-gray-700">Landlord Studio</td>
                <td class="px-6 py-4 text-gray-500">3 Einheiten</td>
                <td class="px-6 py-4 text-gray-500">9,99–24,99 $/Mo</td>
                <td class="px-6 py-4 text-gray-500">2–3 $</td>
              </tr>
              <tr>
                <td class="px-6 py-4 text-gray-700">WISO Vermieter</td>
                <td class="px-6 py-4 text-gray-500">Nein</td>
                <td class="px-6 py-4 text-gray-500">29,99 €/Jahr (Desktop)</td>
                <td class="px-6 py-4 text-gray-500">N/A</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="mt-4 text-center text-xs text-gray-400">
          Preise wie von den jeweiligen Anbietern für 2026 angegeben. Vermietler Plus bietet vollständiges Banking, OCR, Mieterportal und Nebenkosten — Funktionen, für die Wettbewerber deutlich mehr verlangen.
        </p>
      </div>
    </section>

    <!-- Pay-per-use add-ons -->
    <section class="bg-gray-50 py-16">
      <div class="mx-auto max-w-4xl px-6">
        <h2 class="text-center font-display text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">
          Nutzungsbasierte Zusatzleistungen
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-center text-base text-gray-500">
          Verfügbar im Plus-Plan. Sie zahlen nur, was Sie tatsächlich nutzen.
        </p>
        <div class="mt-10 grid gap-4 sm:grid-cols-3">
          <div class="rounded-2xl border border-gray-200 bg-white p-6 text-center shadow-xs">
            <p class="text-xs font-semibold uppercase tracking-wider text-gray-400">Briefversand</p>
            <p class="mt-2 font-display text-3xl font-bold text-gray-900">1,80 €</p>
            <p class="mt-1 text-sm text-gray-500">pro Brief (über Pingen)</p>
          </div>
          <div class="rounded-2xl border border-gray-200 bg-white p-6 text-center shadow-xs">
            <p class="text-xs font-semibold uppercase tracking-wider text-gray-400">Zusatzspeicher</p>
            <p class="mt-2 font-display text-3xl font-bold text-gray-900">0,50 €</p>
            <p class="mt-1 text-sm text-gray-500">pro GB / Monat</p>
          </div>
          <div class="rounded-2xl border border-gray-200 bg-white p-6 text-center shadow-xs">
            <p class="text-xs font-semibold uppercase tracking-wider text-gray-400">Zusatz-OCR</p>
            <p class="mt-2 font-display text-3xl font-bold text-gray-900">2,00 €</p>
            <p class="mt-1 text-sm text-gray-500">Block à 50 Belege</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-white py-16">
      <div class="mx-auto max-w-3xl px-6">
        <h2 class="text-center font-display text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">
          Häufig gestellte Fragen
        </h2>
        <div class="mt-10 divide-y divide-gray-200">
          {faqs.map((faq) => (
            <details class="group py-5">
              <summary class="flex cursor-pointer items-center justify-between text-base font-semibold text-gray-900 [&::-webkit-details-marker]:hidden">
                <h3>{faq.q}</h3>
                <svg class="h-5 w-5 shrink-0 text-gray-400 transition group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-gray-600">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer lang="de" />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    name: "Vermietler",
    description: "Immobilienverwaltungssoftware für deutsche Vermieter",
    brand: { "@type": "Brand", name: "Vermietler" },
    offers: [
      {
        "@type": "Offer",
        name: "Free",
        price: "0",
        priceCurrency: "EUR",
        description: "Kostenloser Plan für Vermieter mit einer Einheit",
      },
      {
        "@type": "Offer",
        name: "Plus",
        price: "4.90",
        priceCurrency: "EUR",
        description: "Plus-Plan jährlich abgerechnet für Vermieter mit bis zu 10 Einheiten",
      },
    ],
  })} />
</Layout>
