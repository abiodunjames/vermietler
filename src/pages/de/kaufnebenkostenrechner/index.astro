---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import ClosingCostCalculator from "../../../components/calculator/ClosingCostCalculator";
import Footer from "../../../components/Footer.astro";

const faqs = [
  {
    q: "Was sind Kaufnebenkosten beim Immobilienkauf?",
    a: "Kaufnebenkosten sind die zusätzlichen Kosten über den Kaufpreis hinaus beim Immobilienerwerb in Deutschland. Dazu gehören Grunderwerbsteuer, Notarkosten, Grundbuchgebühren und ggf. Maklerprovision. Zusammen machen diese üblicherweise 7–12% des Kaufpreises aus."
  },
  {
    q: "Wie hoch ist die Grunderwerbsteuer?",
    a: "Die Grunderwerbsteuer variiert je nach Bundesland zwischen 3,5% in Bayern und 6,5% in Brandenburg, NRW, Saarland und Schleswig-Holstein. Sie wird auf den vollen Kaufpreis berechnet und muss bezahlt werden, bevor die Grundbuchumschreibung erfolgen kann."
  },
  {
    q: "Kann man Notarkosten verhandeln?",
    a: "Nein. Die Notarkosten sind im Gerichts- und Notarkostengesetz (GNotKG) geregelt und nicht verhandelbar. Sie richten sich nach dem Kaufpreis und betragen üblicherweise etwa 1,0–2,0% des Kaufpreises. Alle Immobilientransaktionen in Deutschland müssen gesetzlich notariell beurkundet werden (§ 311b BGB)."
  },
  {
    q: "Wie wirkt sich die Maklerreform 2020 auf Käufer aus?",
    a: "Seit Dezember 2020 schreibt das Gesetz über die Verteilung der Maklerkosten vor, dass Käufer nicht mehr Provision zahlen dürfen als der Verkäufer. In der Praxis zahlen beide Seiten üblicherweise je 3,57% (inkl. 19% MwSt.), insgesamt 7,14%. Bei Privatverkäufen kann die Käuferprovision ganz entfallen."
  },
  {
    q: "Werden Kaufnebenkosten von der Bank finanziert?",
    a: "In der Regel erwarten deutsche Banken, dass Sie die Kaufnebenkosten aus Eigenkapital decken. Die meisten Banken finanzieren bis zu 80–90% des Kaufpreises, aber nicht die Nebenkosten. Das bedeutet, dass Sie mindestens 10–15% des Kaufpreises an Ersparnissen benötigen, um die Kaufnebenkosten zu decken."
  },
  {
    q: "In welchem Bundesland sind die Kaufnebenkosten am niedrigsten?",
    a: "Bayern hat mit 3,5% die niedrigste Grunderwerbsteuer. Zusammen mit den Standardgebühren für Notar und Grundbuch beginnen die Gesamtnebenkosten in Bayern ohne Makler bei ca. 5,5% des Kaufpreises — verglichen mit 8,5% oder mehr in Bundesländern mit 6,5% Grunderwerbsteuer."
  },
  {
    q: "Wie kann ich Kaufnebenkosten reduzieren?",
    a: "Die wichtigste Möglichkeit ist der Kauf ohne Makler (provisionsfrei / Privatverkauf), was 3–4% des Kaufpreises spart. Notar- und Grundbuchgebühren sind gesetzlich festgelegt und nicht verhandelbar. Die Wahl einer Immobilie in einem Bundesland mit niedrigem Steuersatz wie Bayern hilft ebenfalls. Bei Neubauten kann unter Umständen die Trennung von Grundstücks- und Bauvertrag die Grunderwerbsteuer-Bemessungsgrundlage reduzieren."
  },
];
---

<Layout
  title="Kaufnebenkostenrechner 2026 — Nebenkosten beim Immobilienkauf berechnen | Vermietler"
  description="Berechnen Sie alle Kaufnebenkosten beim Immobilienkauf in Deutschland 2026. Grunderwerbsteuer für alle 16 Bundesländer, Notarkosten, Grundbuchgebühren und Maklerprovision. Kostenloser Online-Rechner."
  lang="de"
  keywords="Kaufnebenkostenrechner, Kaufnebenkosten berechnen, Grunderwerbsteuer Rechner, Grunderwerbsteuer 2026, Notarkosten Immobilienkauf, Grundbuchkosten, Maklerprovision Rechner, Nebenkosten Hauskauf, Immobilienkauf Kosten Deutschland, Erwerbsnebenkosten Rechner"
  alternateEn="/closing-cost-calculator"
  alternateDe="/de/kaufnebenkostenrechner"
>
  <Navbar lang="de" />

  <main class="bg-gray-50 pt-28 pb-12 lg:pt-32 lg:pb-16">
    <div class="mx-auto max-w-6xl px-6">
      <ClosingCostCalculator client:load lang="de" />

      <!-- Cross-link CTA -->
      <section class="mt-12">
        <a href="/de/tilgungsrechner" class="group flex items-center justify-between rounded-xl border border-brand-200 bg-brand-50 px-6 py-5 transition hover:border-brand-300 hover:bg-brand-100">
          <div>
            <p class="text-sm font-semibold text-brand-700">Monatliche Rate berechnen</p>
            <p class="mt-1 text-sm text-brand-600/70">Berechnen Sie monatliche Rate, Gesamtzinsen und vollständigen Tilgungsplan für Ihr Annuitätendarlehen.</p>
          </div>
          <svg class="h-5 w-5 shrink-0 text-brand-400 transition group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </section>

      <!-- FAQ section -->
      <section class="mt-20 border-t border-gray-200 pt-12">
        <h2 class="text-2xl font-bold text-gray-900">
          Häufig gestellte Fragen
        </h2>
        <div class="mt-8 divide-y divide-gray-200">
          {faqs.map((faq) => (
            <details class="group py-5">
              <summary class="flex cursor-pointer items-center justify-between text-base font-semibold text-gray-900 [&::-webkit-details-marker]:hidden">
                <h3>{faq.q}</h3>
                <svg class="h-5 w-5 shrink-0 text-gray-400 transition group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-gray-600">{faq.a}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- How to use -->
      <section class="mt-16 border-t border-gray-200 pt-12">
        <h2 class="text-2xl font-bold text-gray-900">
          So verwenden Sie den Kaufnebenkostenrechner
        </h2>
        <div class="mt-6 grid gap-8 text-sm leading-relaxed text-gray-600 sm:grid-cols-2">
          <div>
            <h3 class="mb-2 font-semibold text-gray-900">1. Kaufpreis eingeben</h3>
            <p>Geben Sie den vereinbarten <strong>Kaufpreis</strong> der Immobilie ein. Alle Nebenkosten werden als Prozentsatz dieses Betrags berechnet. Für Neubauten verwenden Sie den Gesamtvertragswert inklusive Mehrwertsteuer.</p>
          </div>
          <div>
            <h3 class="mb-2 font-semibold text-gray-900">2. Bundesland auswählen</h3>
            <p>Wählen Sie das <strong>Bundesland</strong>, in dem sich die Immobilie befindet. Die <strong>Grunderwerbsteuer</strong> variiert von 3,5% in Bayern bis 6,5% in Brandenburg, NRW, Saarland und Schleswig-Holstein.</p>
          </div>
          <div>
            <h3 class="mb-2 font-semibold text-gray-900">3. Maklerprovision anpassen</h3>
            <p>Stellen Sie den Käuferanteil der <strong>Maklerprovision</strong> ein. Seit Dezember 2020 zahlen Käufer maximal 3,57% (50% der üblichen 7,14% gesamt). Bei Privatverkäufen setzen Sie den Wert auf 0%.</p>
          </div>
          <div>
            <h3 class="mb-2 font-semibold text-gray-900">4. Gesamtkapitalbedarf prüfen</h3>
            <p>Der Rechner zeigt Kaufpreis + alle Nebenkosten. Das ist Ihr Gesamtkapitalbedarf — ziehen Sie Ihr Eigenkapital ab, um den <a href="/de/tilgungsrechner" class="text-brand-600 hover:underline">Darlehensbetrag</a> zu ermitteln.</p>
          </div>
        </div>
      </section>

      <!-- Contextual SEO content -->
      <section class="mt-16 border-t border-gray-200 pt-12">
        <h2 class="text-2xl font-bold text-gray-900">
          Kaufnebenkosten beim Immobilienkauf in Deutschland: Ratgeber 2026
        </h2>
        <div class="mt-6 max-w-3xl space-y-4 text-sm leading-relaxed text-gray-600">
          <p>
            Beim Immobilienkauf in Deutschland ist der ausgeschriebene Kaufpreis nur ein Teil der Gesamtkosten. <strong>Kaufnebenkosten</strong> kommen mit üblicherweise 7–12% hinzu — und anders als in manchen Ländern werden diese Kosten fast ausschließlich vom Käufer getragen. Ein genaues Verständnis jeder Komponente hilft Ihnen, realistisch zu budgetieren und Überraschungen beim Notartermin zu vermeiden.
          </p>
          <p>
            Die größte Einzelposition ist die <strong>Grunderwerbsteuer</strong>, die je nach Bundesland zwischen 3,5% in Bayern und 6,5% in Brandenburg, NRW, Saarland und Schleswig-Holstein liegt. Diese Steuer ist nicht verhandelbar und muss bezahlt werden, bevor das Grundbuchamt das Eigentum überträgt. 2026 wird ein möglicher Freibetrag von bis zu 500.000€ für Erstkäufer diskutiert, der jedoch noch nicht in Kraft getreten ist.
          </p>
          <p>
            <strong>Notarkosten</strong> sind im GNotKG geregelt und betragen üblicherweise 1,0–2,0% des Kaufpreises. Seit Juni 2025 sind die Gebühren durch die KostBRÄG-2025-Reform um 6–9% gestiegen. Der Notar wickelt den Kaufvertrag, die Auflassung und ggf. die Grundschuldbestellung ab.
          </p>
          <p>
            Sobald Sie Ihre Gesamtnebenkosten kennen, nutzen Sie unseren <a href="/de/tilgungsrechner" class="text-brand-600 hover:underline">Tilgungsrechner</a>, um Ihre monatliche Rate zu berechnen — basierend auf dem Darlehensbetrag, der sich aus Kaufpreis plus Nebenkosten minus Eigenkapital ergibt.
          </p>
        </div>
      </section>
    </div>
  </main>

  <Footer lang="de" />

  <!-- JSON-LD: WebApplication -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "Kaufnebenkostenrechner",
    alternateName: "Closing Cost Calculator for Germany",
    url: "https://vermietler.com/de/kaufnebenkostenrechner",
    applicationCategory: "FinanceApplication",
    operatingSystem: "Web",
    offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" },
    description: "Kostenloser Kaufnebenkostenrechner für den Immobilienkauf in Deutschland. Berechnen Sie Grunderwerbsteuer, Notarkosten, Grundbuchgebühren und Maklerprovision für alle 16 Bundesländer.",
    inLanguage: ["de", "en"],
    publisher: {
      "@type": "Organization",
      name: "Vermietler",
      url: "https://vermietler.com",
    },
    dateModified: "2026-03-22",
  })} />

  <!-- JSON-LD: FAQPage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  })} />

  <!-- JSON-LD: BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Startseite", item: "https://vermietler.com/de/" },
      { "@type": "ListItem", position: 2, name: "Kaufnebenkostenrechner", item: "https://vermietler.com/de/kaufnebenkostenrechner" },
    ],
  })} />

  <!-- JSON-LD: HowTo -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    name: "So berechnen Sie Kaufnebenkosten beim Immobilienkauf",
    description: "Nutzen Sie diesen kostenlosen Rechner, um alle Kaufnebenkosten beim Immobilienerwerb in Deutschland zu ermitteln — Grunderwerbsteuer, Notar, Grundbuch und Makler.",
    step: [
      { "@type": "HowToStep", position: 1, name: "Kaufpreis eingeben", text: "Geben Sie den vereinbarten Kaufpreis der Immobilie ein. Alle Nebenkosten werden prozentual berechnet." },
      { "@type": "HowToStep", position: 2, name: "Bundesland auswählen", text: "Wählen Sie das Bundesland der Immobilie. Die Grunderwerbsteuer liegt zwischen 3,5% und 6,5%." },
      { "@type": "HowToStep", position: 3, name: "Maklerprovision anpassen", text: "Stellen Sie den Käuferanteil der Maklerprovision ein. Maximal 3,57% seit 2020. Bei Privatverkäufen 0%." },
      { "@type": "HowToStep", position: 4, name: "Gesamtkapitalbedarf prüfen", text: "Der Rechner zeigt Kaufpreis plus alle Nebenkosten — Ihr gesamter Kapitalbedarf für den Immobilienkauf." },
    ],
  })} />
</Layout>
