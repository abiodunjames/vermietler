---
import Layout from "../../../layouts/Layout.astro";
import ClosingCostCalculator from "../../../components/calculator/ClosingCostCalculator";
import Footer from "../../../components/Footer.astro";

const faqs = [
  {
    q: "Was sind Kaufnebenkosten beim Immobilienkauf?",
    a: "Kaufnebenkosten sind die zusätzlichen Kosten über den Kaufpreis hinaus beim Immobilienerwerb in Deutschland. Dazu gehören Grunderwerbsteuer, Notarkosten, Grundbuchgebühren und ggf. Maklerprovision. Zusammen machen diese üblicherweise 7–12% des Kaufpreises aus."
  },
  {
    q: "Wie hoch ist die Grunderwerbsteuer?",
    a: "Die Grunderwerbsteuer variiert je nach Bundesland zwischen 3,5% in Bayern und 6,5% in Brandenburg, NRW, Saarland und Schleswig-Holstein. Sie wird auf den vollen Kaufpreis berechnet und muss bezahlt werden, bevor die Grundbuchumschreibung erfolgen kann."
  },
  {
    q: "Kann man Notarkosten verhandeln?",
    a: "Nein. Die Notarkosten sind im Gerichts- und Notarkostengesetz (GNotKG) geregelt und nicht verhandelbar. Sie richten sich nach dem Kaufpreis und betragen üblicherweise etwa 1,0–2,0% des Kaufpreises. Alle Immobilientransaktionen in Deutschland müssen gesetzlich notariell beurkundet werden (§ 311b BGB)."
  },
  {
    q: "Wie wirkt sich die Maklerreform 2020 auf Käufer aus?",
    a: "Seit Dezember 2020 schreibt das Gesetz über die Verteilung der Maklerkosten vor, dass Käufer nicht mehr Provision zahlen dürfen als der Verkäufer. In der Praxis zahlen beide Seiten üblicherweise je 3,57% (inkl. 19% MwSt.), insgesamt 7,14%. Bei Privatverkäufen kann die Käuferprovision ganz entfallen."
  },
  {
    q: "Werden Kaufnebenkosten von der Bank finanziert?",
    a: "In der Regel erwarten deutsche Banken, dass Sie die Kaufnebenkosten aus Eigenkapital decken. Die meisten Banken finanzieren bis zu 80–90% des Kaufpreises, aber nicht die Nebenkosten. Das bedeutet, dass Sie mindestens 10–15% des Kaufpreises an Ersparnissen benötigen, um die Kaufnebenkosten zu decken."
  },
];
---

<Layout
  title="Kaufnebenkostenrechner — Kostenloser Nebenkosten-Rechner | Vermietler"
  description="Berechnen Sie alle Kaufnebenkosten beim Immobilienkauf in Deutschland — Grunderwerbsteuer, Notarkosten, Grundbuchgebühren und Maklerprovision. Kostenloser Online-Rechner für alle 16 Bundesländer."
  lang="de"
>
  <!-- Navbar minimal -->
  <nav class="border-b border-gray-100 bg-white">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/de/"><img src="/images/logo-compact.svg" alt="Vermietler" class="h-7" /></a>
      <a href="/closing-cost-calculator" class="text-sm text-gray-500 hover:text-gray-900 transition">English</a>
    </div>
  </nav>

  <main class="bg-gray-50 py-12 lg:py-16">
    <div class="mx-auto max-w-6xl px-6">
      <ClosingCostCalculator client:load lang="de" />

      <!-- FAQ section for SEO -->
      <section class="mt-20 border-t border-gray-200 pt-12">
        <h2 class="text-2xl font-bold text-gray-900">
          Häufig gestellte Fragen
        </h2>
        <div class="mt-8 divide-y divide-gray-200">
          {faqs.map((faq) => (
            <details class="group py-5">
              <summary class="flex cursor-pointer items-center justify-between text-base font-semibold text-gray-900 [&::-webkit-details-marker]:hidden">
                <h3>{faq.q}</h3>
                <svg class="h-5 w-5 shrink-0 text-gray-400 transition group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-gray-600">{faq.a}</p>
            </details>
          ))}
        </div>
      </section>
    </div>
  </main>

  <Footer lang="de" />

  <!-- JSON-LD: WebApplication -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "Kaufnebenkostenrechner",
    alternateName: "Closing Cost Calculator for Germany",
    url: "https://vermietler.com/de/kaufnebenkostenrechner",
    applicationCategory: "FinanceApplication",
    operatingSystem: "Web",
    offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" },
    description: "Kostenloser Kaufnebenkostenrechner für den Immobilienkauf in Deutschland. Berechnen Sie Grunderwerbsteuer, Notarkosten, Grundbuchgebühren und Maklerprovision für alle 16 Bundesländer.",
    inLanguage: ["de", "en"],
  })} />

  <!-- JSON-LD: FAQPage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  })} />

  <!-- JSON-LD: BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Startseite", item: "https://vermietler.com/de/" },
      { "@type": "ListItem", position: 2, name: "Kaufnebenkostenrechner", item: "https://vermietler.com/de/kaufnebenkostenrechner" },
    ],
  })} />
</Layout>
