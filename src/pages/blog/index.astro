---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import BlogPostCard from "../../components/BlogPostCard.astro";

const posts = (await getCollection("blog"))
  .filter((post) => post.data.lang === "en")
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = posts[0];
const rest = posts.slice(1);
---

<Layout
  title="Blog — Vermietler"
  description="Tips, guides, and news for landlords managing rental properties in Germany. Mietrecht, financing, Nebenkosten, and more."
  alternateEn="/blog"
  alternateDe="/de/blog"
>
  <Navbar lang="en" />

  {/* Hero */}
  <div class="relative overflow-hidden pt-28 pb-12" style="background:linear-gradient(160deg,#1e2d45 0%,#2d4068 55%,#1a3560 100%)">
    <div class="pointer-events-none absolute inset-0 opacity-[0.04]" style="background-image:url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%2360a5fa'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E&quot;);background-repeat:repeat;"></div>
    <div class="relative mx-auto max-w-[1160px] px-8">
      <div class="flex items-center gap-2 text-[13px] text-white/40 mb-5">
        <a href="/" class="text-white/50 no-underline transition hover:text-white/80">Home</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0"><polyline points="9 18 15 12 9 6"/></svg>
        <span>Blog</span>
      </div>
      <h1 class="font-display text-[clamp(28px,3.5vw,44px)] font-bold leading-[1.15] tracking-tight text-white" style="letter-spacing:-0.03em">
        Blog
      </h1>
      <p class="mt-3 max-w-[560px] text-[17px] leading-relaxed text-white/55">
        Guides, legal updates, and practical tools for landlords managing rental properties in Germany.
      </p>

      {/* Stats bar */}
      <div class="mt-8 flex flex-wrap items-center gap-6 border-t border-white/10 pt-5">
        <div class="flex items-center gap-2 text-[13px] text-white/40">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <strong class="font-medium text-white/70">{posts.length} articles</strong>
        </div>
        <div class="flex items-center gap-2 text-[13px] text-white/40">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <strong class="font-medium text-white/70">Updated weekly</strong>
        </div>
      </div>
    </div>
  </div>

  <main class="bg-gray-50 pb-16">
    <div class="mx-auto max-w-[1160px] px-8">

      {posts.length === 0 ? (
        <div class="py-20 text-center">
          <p class="text-gray-500">No posts yet. Check back soon!</p>
        </div>
      ) : (
        <>
          {/* Featured post */}
          {featured && (
            <div class="-mt-10 relative z-10 mb-8">
              <a href={`/blog/${featured.id.replace(/^en\//, "")}`} class="group block overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-lg transition-all duration-200 hover:-translate-y-[2px] hover:shadow-xl hover:border-brand-200">
                <div class="grid md:grid-cols-[1fr_1.2fr]">
                  {/* Featured color strip */}
                  <div class="relative h-[200px] md:h-auto bg-gradient-to-br from-blue-800 to-brand-500">
                    <div class="absolute inset-0 opacity-[0.08]" style="background-image:url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E&quot;);background-repeat:repeat;"></div>
                    <div class="absolute bottom-4 left-5">
                      <span class="inline-flex items-center gap-1.5 rounded-full bg-white/15 border border-white/20 px-3 py-1 text-xs font-semibold text-white backdrop-blur-sm">
                        Latest
                      </span>
                    </div>
                  </div>
                  {/* Featured body */}
                  <div class="flex flex-col justify-center p-7 md:p-8">
                    <div class="flex flex-wrap gap-2 mb-3">
                      {featured.data.tags.slice(0, 3).map((tag: string) => (
                        <span class="rounded-full bg-brand-50 px-2.5 py-0.5 text-[11px] font-semibold text-brand-700">{tag}</span>
                      ))}
                    </div>
                    <h2 class="font-display text-xl font-bold leading-snug tracking-tight text-gray-900 transition group-hover:text-brand-600 md:text-2xl" style="letter-spacing:-0.02em">
                      {featured.data.title}
                    </h2>
                    <p class="mt-3 text-sm leading-relaxed text-gray-500 line-clamp-3">
                      {featured.data.description}
                    </p>
                    <div class="mt-5 flex items-center gap-3">
                      <div class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-100 font-display text-[10px] font-bold text-brand-700">
                        {featured.data.author.split(" ").map((w: string) => w[0]).join("").slice(0, 2).toUpperCase()}
                      </div>
                      <div>
                        <div class="text-xs font-medium text-gray-800">{featured.data.author}</div>
                        <div class="text-[11px] text-gray-400">
                          {featured.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </a>
            </div>
          )}

          {/* Rest of posts */}
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {rest.map((post) => (
              <BlogPostCard
                title={post.data.title}
                description={post.data.description}
                date={post.data.date}
                author={post.data.author}
                slug={post.id.replace(/^en\//, "")}
                tags={post.data.tags}
                lang="en"
              />
            ))}
          </div>
        </>
      )}
    </div>
  </main>

  <Footer lang="en" />
</Layout>
