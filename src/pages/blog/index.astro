---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import BlogPostCard from "../../components/BlogPostCard.astro";

const posts = (await getCollection("blog"))
  .filter((post) => post.data.lang === "en")
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Blog — Vermietler"
  description="Tips, guides, and news for landlords. Learn how to manage your properties more efficiently."
>
  <nav class="border-b border-gray-100 bg-white">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <!-- <a href="/"><img src="/images/logo-compact.svg" alt="Vermietler" class="h-7" /></a> -->
      <img src="/images/logo-compact.svg" alt="Vermietler" class="h-7" />
      <!-- <a href="/de/blog" class="text-sm text-gray-500 hover:text-gray-900 transition">Deutsch</a> -->
    </div>
  </nav>
  <main class="bg-gray-50 py-16">
    <div class="mx-auto max-w-4xl px-6">
      <header class="text-center">
        <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Blog</h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-500">
          Tips, guides, and updates for landlords who want to work smarter.
        </p>
      </header>

      {posts.length === 0 ? (
        <div class="mt-16 text-center">
          <p class="text-gray-500">No posts yet. Check back soon!</p>
        </div>
      ) : (
        <div class="mt-12 grid gap-6 sm:grid-cols-2">
          {posts.map((post) => (
            <BlogPostCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              author={post.data.author}
              slug={post.id.replace(/^en\//, "")}
              tags={post.data.tags}
              lang="en"
            />
          ))}
        </div>
      )}
    </div>
  </main>
  <Footer lang="en" />
</Layout>
