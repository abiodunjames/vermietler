---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

const calculators = [
  {
    name: "Closing Cost Calculator",
    nameDe: "Kaufnebenkostenrechner",
    href: "/closing-cost-calculator",
    eyebrow: "Buying",
    summary: "Estimate Grunderwerbsteuer, notary, land registry, and agent fees for every German Bundesland. Shows your total capital requirement before financing.",
    bullets: [
      "All 16 states with current 2026 rates (3.5%-6.5%)",
      "Notary + Grundbuch + Maklerprovision",
      "Total transaction cost in euros",
    ],
    category: "acquisition",
    colors: { bg: "bg-amber-50", text: "text-amber-700", icon: "text-amber-500" },
    icon: '<path d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>',
  },
  {
    name: "Mortgage Calculator",
    nameDe: "Hypothekenrechner",
    href: "/hypothekenrechner",
    eyebrow: "Buying",
    summary: "Model your Annuitätendarlehen. Monthly Rate, full amortization, total interest over Zinsbindung, and Sondertilgung impact.",
    bullets: [
      "Annual annuity = (rate + Tilgung) × loan amount",
      "Year-by-year amortization schedule",
      "Sondertilgung + Tilgungssatzwechsel modelling",
    ],
    category: "acquisition",
    colors: { bg: "bg-cyan-50", text: "text-cyan-700", icon: "text-cyan-600" },
    icon: '<path d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z"/>',
  },
  {
    name: "Rental Yield Calculator",
    nameDe: "Mietrenditerechner",
    href: "/rental-yield-calculator",
    eyebrow: "Returns",
    summary: "See gross yield, net yield, and cash-on-cash return for any rental property. Factors in non-allocable Hausgeld, vacancy, and management costs.",
    bullets: [
      "Bruttomietrendite vs. Nettomietrendite",
      "Faktor (Vervielfältiger) breakdown",
      "Operating cost-adjusted return",
    ],
    category: "returns",
    colors: { bg: "bg-emerald-50", text: "text-emerald-700", icon: "text-emerald-600" },
    icon: '<path d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"/>',
  },
  {
    name: "Mietpreisbremse Calculator",
    nameDe: "Mietpreisbremse-Rechner",
    href: "/mietpreisbremse-rechner",
    eyebrow: "Compliance",
    summary: "Check whether your rent complies with the Mietpreisbremse. Compute the maximum legal rent for any apartment and assess refund risk.",
    bullets: [
      "Ortsübliche Vergleichsmiete + 10% cap",
      "Mietspiegel-based calculation",
      "Rüge refund-liability estimate",
    ],
    category: "operations",
    colors: { bg: "bg-purple-50", text: "text-purple-700", icon: "text-purple-600" },
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  },
  {
    name: "AfA Calculator",
    nameDe: "AfA-Rechner",
    href: "/afa-calculator",
    eyebrow: "Tax",
    summary: "Estimate your annual depreciation (Absetzung für Abnutzung). Supports 2%, 3% (post-2023 buildings), and the new degressive option.",
    bullets: [
      "Linear 2% / 3% / degressive 5%",
      "Building share of purchase price",
      "Annual + cumulative depreciation",
    ],
    category: "tax",
    colors: { bg: "bg-brand-50", text: "text-brand-700", icon: "text-brand-600" },
    icon: '<path d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9z"/>',
  },
  {
    name: "Anlage V Tax Calculator",
    nameDe: "Anlage V Rechner",
    href: "/anlage-v-tax-calculator",
    eyebrow: "Tax",
    summary: "Estimate your annual rental income tax. Fills in the key Anlage V positions: Einnahmen, Werbungskosten, AfA, Schuldzinsen.",
    bullets: [
      "Rental profit/loss calculation",
      "Werbungskosten breakdown",
      "Tax impact at your marginal rate",
    ],
    category: "tax",
    colors: { bg: "bg-red-50", text: "text-red-700", icon: "text-red-600" },
    icon: '<path d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"/>',
  },
];

const groups = [
  { id: "acquisition", title: "Buying a property", desc: "Run the numbers before you sign the Kaufvertrag." },
  { id: "returns", title: "Returns & yield", desc: "Know what the property actually earns after costs." },
  { id: "operations", title: "Operations & rent setting", desc: "Stay compliant with German tenancy law." },
  { id: "tax", title: "Tax & depreciation", desc: "Optimise your Steuererklärung as a landlord." },
];

const faqs = [
  {
    q: "Are the calculators free?",
    a: "Yes. All calculators are free, unlimited, and require no signup. They run entirely in your browser, and no data is stored or sent to a server.",
  },
  {
    q: "Which calculator should I start with?",
    a: "If you're considering a purchase, start with the Closing Cost Calculator to size your equity requirement, then the Mortgage Calculator for the monthly rate, and the Rental Yield Calculator to confirm the property actually makes financial sense. For existing landlords, the Anlage V Tax Calculator and AfA Calculator are the highest-value tools.",
  },
  {
    q: "Do the calculators reflect 2026 tax rates and rules?",
    a: "Yes. All calculators are updated for the 2026 tax year: current Grunderwerbsteuer rates in all 16 Bundesländer, the 3% AfA rate for buildings completed from 2023, the latest Mietpreisbremse rules, and current Anlage V form fields.",
  },
  {
    q: "Can I use the calculators in German or English?",
    a: "Yes. Every calculator is available in both English and German. The German version uses German number formatting (1.234,56 €) and standard German real-estate terminology (Kaltmiete, Hausgeld, Tilgung, AfA, etc.).",
  },
  {
    q: "How accurate are the projections?",
    a: "The calculators use standard formulas accepted by German banks, tax offices, and BetrKV. Outputs are illustrative and depend on the values you enter. For binding decisions, especially tax and financing, confirm results with your Steuerberater and your bank.",
  },
  {
    q: "Are the calculators DSGVO compliant?",
    a: "Yes. All computation happens locally in your browser. We don't store, transmit, or share any of the values you enter. The site itself uses only essential cookies and a minimal analytics setup hosted in the EU.",
  },
];
---

<Layout
  title="Free Calculators for German Landlords | Vermietler"
  description="Free calculators for buying, financing, renting, and taxing real estate in Germany. Closing costs, mortgage, rental yield, AfA depreciation, Mietpreisbremse, Anlage V tax. EN/DE, no signup, DSGVO compliant."
  keywords="real estate calculators germany, landlord calculators, Immobilienrechner, Vermieter Rechner, mortgage calculator germany, closing cost calculator germany, rental yield calculator germany, AfA calculator, Mietpreisbremse calculator, Anlage V calculator, Grunderwerbsteuer Rechner"
  alternateEn="/calculators"
  alternateDe="/de/rechner"
>
  <Navbar lang="en" />

  <!-- Hero -->
  <header class="bg-gradient-to-b from-brand-50/40 to-white pt-28 pb-12 lg:pt-32 lg:pb-16">
    <div class="mx-auto max-w-5xl px-6 text-center">
      <p class="mb-3 inline-flex items-center gap-1.5 rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-700">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        6 free calculators · 2026 edition
      </p>
      <h1 class="font-display text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl" style="letter-spacing:-0.025em">
        Calculators for German landlords
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-gray-600">
        Free, no-signup tools for every stage of the rental property lifecycle. Buy, finance, rent, and tax with the same numbers your bank, Steuerberater, and Finanzamt use.
      </p>
    </div>
  </header>

  <main class="bg-white pb-20">
    <div class="mx-auto max-w-5xl px-6">

      <!-- Grouped calculator cards -->
      {groups.map((group) => (
        <section class="mt-14 first:mt-0">
          <div class="mb-6">
            <h2 class="font-display text-2xl font-bold tracking-tight text-gray-900" style="letter-spacing:-0.02em">{group.title}</h2>
            <p class="mt-1 text-sm text-gray-500">{group.desc}</p>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            {calculators.filter((c) => c.category === group.id).map((calc) => (
              <a
                href={calc.href}
                class="group relative flex flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white p-6 shadow-xs transition hover:-translate-y-[2px] hover:border-brand-200 hover:shadow-md"
              >
                <div class={`mb-4 flex h-11 w-11 items-center justify-center rounded-xl ${calc.colors.bg}`}>
                  <svg class={`h-5 w-5 ${calc.colors.icon}`} fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" set:html={calc.icon} />
                </div>
                <p class={`mb-1 text-[11px] font-semibold uppercase tracking-[0.1em] ${calc.colors.text}`}>{calc.eyebrow}</p>
                <h3 class="font-display text-lg font-bold text-gray-900 transition group-hover:text-brand-600" style="letter-spacing:-0.01em">{calc.name}</h3>
                <p class="mt-2 text-sm leading-relaxed text-gray-500">{calc.summary}</p>
                <ul class="mt-4 space-y-1.5 text-xs text-gray-500">
                  {calc.bullets.map((b) => (
                    <li class="flex items-start gap-2">
                      <svg class="mt-0.5 h-3.5 w-3.5 shrink-0 text-brand-400" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><polyline points="20 6 9 17 4 12"/></svg>
                      <span>{b}</span>
                    </li>
                  ))}
                </ul>
                <div class="mt-5 flex items-center gap-1.5 text-sm font-semibold text-brand-600">
                  Open calculator
                  <svg class="h-4 w-4 transition group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}

      <!-- The full lifecycle flow -->
      <section class="mt-20 rounded-2xl border border-gray-200 bg-gray-50 p-8">
        <h2 class="font-display text-2xl font-bold tracking-tight text-gray-900" style="letter-spacing:-0.02em">How to use them together</h2>
        <p class="mt-2 text-sm text-gray-600">A typical buy-and-hold landlord runs these in sequence:</p>
        <ol class="mt-6 space-y-4">
          <li class="flex gap-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-500 text-sm font-bold text-white">1</span>
            <div>
              <p class="text-sm font-semibold text-gray-900"><a href="/closing-cost-calculator" class="text-brand-600 hover:underline">Closing Cost Calculator</a> + <a href="/hypothekenrechner" class="text-brand-600 hover:underline">Mortgage Calculator</a></p>
              <p class="mt-1 text-sm text-gray-600">Confirm your total equity need (purchase price + closing costs) and the monthly Annuität before viewings.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-500 text-sm font-bold text-white">2</span>
            <div>
              <p class="text-sm font-semibold text-gray-900"><a href="/rental-yield-calculator" class="text-brand-600 hover:underline">Rental Yield Calculator</a></p>
              <p class="mt-1 text-sm text-gray-600">Stress-test gross and net yield against the asking rent. If net yield is below ~3% after non-allocable costs, the deal usually doesn't work.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-500 text-sm font-bold text-white">3</span>
            <div>
              <p class="text-sm font-semibold text-gray-900"><a href="/mietpreisbremse-rechner" class="text-brand-600 hover:underline">Mietpreisbremse Calculator</a></p>
              <p class="mt-1 text-sm text-gray-600">Before you sign a new tenant, check the legal maximum rent for your address. The cap can be 20-30% below market in tight cities.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-500 text-sm font-bold text-white">4</span>
            <div>
              <p class="text-sm font-semibold text-gray-900"><a href="/afa-calculator" class="text-brand-600 hover:underline">AfA Calculator</a> + <a href="/anlage-v-tax-calculator" class="text-brand-600 hover:underline">Anlage V Tax Calculator</a></p>
              <p class="mt-1 text-sm text-gray-600">At year-end, calculate your depreciation and complete the Anlage V form. Most rental properties show a tax loss in the early years that reduces your other income tax.</p>
            </div>
          </li>
        </ol>
      </section>

      <!-- FAQ -->
      <section class="mt-20 border-t border-gray-200 pt-12">
        <h2 class="font-display text-2xl font-bold tracking-tight text-gray-900" style="letter-spacing:-0.02em">Frequently asked questions</h2>
        <div class="mt-8 divide-y divide-gray-200">
          {faqs.map((faq) => (
            <details class="group py-5">
              <summary class="flex cursor-pointer items-center justify-between text-base font-semibold text-gray-900 [&::-webkit-details-marker]:hidden">
                <h3>{faq.q}</h3>
                <svg class="h-5 w-5 shrink-0 text-gray-400 transition group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-gray-600">{faq.a}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- CTA -->
      <section class="mt-20 overflow-hidden rounded-2xl border border-brand-200 bg-gradient-to-br from-brand-50 to-white p-8 lg:p-10">
        <div class="flex flex-col items-start gap-6 lg:flex-row lg:items-center lg:justify-between">
          <div>
            <h2 class="font-display text-2xl font-bold tracking-tight text-gray-900" style="letter-spacing:-0.02em">Beyond the calculators</h2>
            <p class="mt-2 max-w-xl text-sm leading-relaxed text-gray-600">Vermietler turns these calculators into an integrated rental management platform. Track real rent, real expenses, real cash flow, and generate Nebenkostenabrechnungen automatically.</p>
          </div>
          <a href="https://app.vermietler.com/signup" class="inline-flex shrink-0 items-center gap-2 rounded-full bg-brand-500 px-6 py-3 text-sm font-semibold text-white shadow-lg transition hover:bg-brand-600 hover:-translate-y-px">
            Start free
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>
      </section>
    </div>
  </main>

  <Footer lang="en" />

  <!-- JSON-LD: ItemList for calculators -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "Free Calculators for German Landlords",
    description: "A collection of free, browser-based calculators for buying, financing, renting, and taxing real estate in Germany.",
    itemListOrder: "http://schema.org/ItemListOrderAscending",
    numberOfItems: calculators.length,
    itemListElement: calculators.map((c, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `https://vermietler.com${c.href}`,
      name: c.name,
      description: c.summary,
    })),
  })} />

  <!-- JSON-LD: WebApplication for collection -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Free Calculators for German Landlords",
    url: "https://vermietler.com/calculators",
    inLanguage: ["en", "de"],
    publisher: { "@type": "Organization", name: "Vermietler", url: "https://vermietler.com" },
    dateModified: "2026-05-21",
  })} />

  <!-- JSON-LD: FAQPage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  })} />

  <!-- JSON-LD: BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://vermietler.com/" },
      { "@type": "ListItem", position: 2, name: "Calculators", item: "https://vermietler.com/calculators" },
    ],
  })} />
</Layout>
