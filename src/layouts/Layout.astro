---
interface Props {
  title: string;
  description: string;
  lang?: string;
  ogImage?: string;
  keywords?: string;
  alternateEn?: string;
  alternateDe?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  lang = "en",
  ogImage = "/images/og-default.png",
  keywords,
  alternateEn,
  alternateDe,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// hreflang: use explicit alternates when provided, fallback to auto-detection
const enURL = alternateEn
  ? new URL(alternateEn, Astro.site)
  : new URL(Astro.url.pathname.replace(/^\/de\//, "/"), Astro.site);
const deURL = alternateDe
  ? new URL(alternateDe, Astro.site)
  : new URL(Astro.url.pathname.startsWith("/de/") ? Astro.url.pathname : `/de${Astro.url.pathname}`, Astro.site);

const posthogKey = process.env.PUBLIC_POSTHOG_KEY || "";

import "../styles/global.css";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Language auto-redirect (must run before render to avoid flash) -->
    <script is:inline>
      (function () {
        try {
          var path = window.location.pathname;
          var search = window.location.search;
          var hash = window.location.hash;
          var KEY = 'vermietler_lang';

          // If the URL carries ?lang=en, the user explicitly chose English.
          // Record the preference and strip the query param.
          if (search.indexOf('lang=en') !== -1) {
            localStorage.setItem(KEY, 'en');
            var cleaned = search.replace(/([?&])lang=en(&|$)/, function (_, p1, p2) {
              return p2 ? p1 : '';
            }).replace(/\?$/, '');
            window.history.replaceState({}, '', path + cleaned + hash);
          }

          // On any DE page, mark preference as DE (sticky on subsequent visits).
          if (path === '/de' || path === '/de/' || path.indexOf('/de/') === 0) {
            if (localStorage.getItem(KEY) !== 'de') {
              localStorage.setItem(KEY, 'de');
            }
            return;
          }

          // Only auto-redirect on the EN root.
          if (path !== '/' && path !== '') return;

          var pref = localStorage.getItem(KEY);
          if (pref === 'de') {
            window.location.replace('/de/');
            return;
          }
          if (pref === 'en') return; // user has been here; respect their choice

          // First visit: check browser language.
          var lang = (navigator.language || navigator.userLanguage || '').toLowerCase();
          if (lang.indexOf('de') === 0) {
            localStorage.setItem(KEY, 'de');
            window.location.replace('/de/');
          } else {
            localStorage.setItem(KEY, 'en');
          }
        } catch (e) {
          // localStorage / navigator unavailable — fail silently
        }
      })();
    </script>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    {keywords && <meta name="keywords" content={keywords} />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Vermietler" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content={lang === "de" ? "de_DE" : "en_US"} />
    {lang === "en" && <meta property="og:locale:alternate" content="de_DE" />}
    {lang === "de" && <meta property="og:locale:alternate" content="en_US" />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- hreflang for i18n SEO -->
    <link rel="alternate" hreflang="en" href={enURL} />
    <link rel="alternate" hreflang="de" href={deURL} />
    <link rel="alternate" hreflang="x-default" href={enURL} />

    <!-- Fonts: DM Sans (body) + Space Grotesk (display) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- Structured Data: Organization (site-wide) -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        "@id": "https://vermietler.com/#organization",
        name: "Vermietler",
        legalName: "Vermietler",
        url: "https://vermietler.com",
        logo: {
          "@type": "ImageObject",
          url: "https://vermietler.com/images/logo-compact.svg",
          width: 512,
          height: 512,
        },
        image: "https://vermietler.com/images/og-default.png",
        description:
          lang === "de"
            ? "Die All-in-One-Plattform für private Vermieter in Deutschland. Kostenlose Rechner, Fachartikel zu Mietrecht, Steuern, Finanzierung und Vermietungssoftware."
            : "The all-in-one platform for private landlords in Germany. Free calculators, expert content on Mietrecht, tax, financing, and rental management software.",
        address: {
          "@type": "PostalAddress",
          streetAddress: "Glockenturmstraße 30",
          postalCode: "14055",
          addressLocality: "Berlin",
          addressCountry: "DE",
        },
        contactPoint: {
          "@type": "ContactPoint",
          contactType: "customer support",
          email: "info@vermietler.com",
          telephone: "+49-30-91204795",
          availableLanguage: ["German", "English"],
        },
        areaServed: { "@type": "Country", name: "Germany" },
        knowsAbout: [
          "Mietrecht",
          "German rental law",
          "Nebenkostenabrechnung",
          "Mietpreisbremse",
          "AfA",
          "Anlage V",
          "Annuitätendarlehen",
          "Hausgeld",
          "Grunderwerbsteuer",
          "Verkehrssicherungspflicht",
        ],
        sameAs: [
          "https://www.linkedin.com/company/vermietler",
        ],
      })}
    />

    <!-- Structured Data: WebSite with SearchAction -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": "https://vermietler.com/#website",
        url: "https://vermietler.com",
        name: "Vermietler",
        description:
          lang === "de"
            ? "Kostenlose Rechner und Fachinhalte für private Vermieter in Deutschland."
            : "Free calculators and expert content for private landlords in Germany.",
        inLanguage: lang === "de" ? "de-DE" : "en-US",
        publisher: { "@id": "https://vermietler.com/#organization" },
      })}
    />

    <!-- PostHog -->
    {posthogKey && <meta name="ph-key" content={posthogKey} />}
    <script is:inline>
      (function(){
        var k = document.querySelector('meta[name="ph-key"]');
        if (!k) return;
        var key = k.getAttribute('content');
        k.remove();
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://eu-assets.i.posthog.com/static/array.js';
        s.onload = function(){
          window.posthog.init(key, {
            api_host: 'https://eu.i.posthog.com',
            person_profiles: 'identified_only'
          });
        };
        document.head.appendChild(s);
      })();
    </script>
  </head>
  <body class="bg-white">
    <slot />

    <!-- Tawk.to live chat (homepage + blog only, localised by language) -->
    <script is:inline define:vars={{ lang }}>
      (function(){
        var p = window.location.pathname.replace(/\/+$/, '') || '/';
        var show = p === '' || p === '/' || p === '/de' || p.indexOf('/blog') !== -1;
        if (!show) return;

        var isDE = lang === 'de';
        // English widget: 1jmbri85a | German widget: replace with your DE widget hash
        var widgetId = isDE ? '1jmd4d4ub' : '1jmbri85a';
        var propertyId = '69e135891dd97e1c38bed1e6';

        var Tawk_API = window.Tawk_API || {};
        window.Tawk_API = Tawk_API;
        window.Tawk_LoadStart = new Date();

        // Set Tawk language
        Tawk_API.language = isDE ? 'de' : 'en';

        var s1 = document.createElement("script"), s0 = document.getElementsByTagName("script")[0];
        s1.async = true;
        s1.src = 'https://embed.tawk.to/' + propertyId + '/' + widgetId;
        s1.charset = 'UTF-8';
        s1.setAttribute('crossorigin', '*');
        s0.parentNode.insertBefore(s1, s0);
      })();
    </script>
  </body>
</html>
