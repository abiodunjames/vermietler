---
interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;

const t = {
  en: {
    badge: "Built for private landlords",
    headline: "Property management,",
    headlineAccent: "simplified.",
    sub: "Stop juggling spreadsheets, emails, and paper folders. Vermietler centralizes your properties, finances, tenants, and documents in one clean platform.",
    cta: "Start for free",
    ctaSecondary: "See how it works",
    stat1Label: "Admin time saved",
    stat1Value: "70%",
    stat2Label: "Faster statements",
    stat2Value: "10x",
    stat3Label: "DSGVO compliant",
    stat3Value: "100%",
  },
  de: {
    badge: "Entwickelt für deutsche Vermieter",
    headline: "Immobilienverwaltung,",
    headlineAccent: "vereinfacht.",
    sub: "Schluss mit Tabellen, E-Mails und Papierakten. Vermietler bündelt Ihre Immobilien, Finanzen, Mieter und Dokumente in einer übersichtlichen Plattform.",
    cta: "Kostenlos starten",
    ctaSecondary: "So funktioniert's",
    stat1Label: "Verwaltungszeit gespart",
    stat1Value: "70%",
    stat2Label: "Schnellere Abrechnungen",
    stat2Value: "10x",
    stat3Label: "DSGVO-konform",
    stat3Value: "100%",
  },
}[lang]!;
---

<section class="relative overflow-hidden pt-32 pb-20 lg:pt-40 lg:pb-32">
  <!-- Background gradient -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute top-0 left-1/2 h-[600px] w-[900px] -translate-x-1/2 rounded-full bg-brand-50 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-6xl px-6 text-center">
    <!-- Badge -->
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-25 px-4 py-1.5 text-sm font-medium text-brand-700">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" />
      </svg>
      {t.badge}
    </div>

    <!-- Headline with display font -->
    <h1 class="mx-auto max-w-4xl font-display text-5xl font-semibold tracking-tight text-gray-900 sm:text-6xl lg:text-7xl">
      {t.headline}
      <br />
      <span class="bg-gradient-to-r from-brand-500 to-brand-400 bg-clip-text text-transparent">
        {t.headlineAccent}
      </span>
    </h1>

    <!-- Subheadline -->
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-gray-500 sm:text-xl">
      {t.sub}
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="#pricing"
        class="inline-flex items-center gap-2 rounded-xl bg-brand-500 px-8 py-3.5 text-base font-semibold text-white shadow-md transition hover:bg-brand-600 hover:shadow-lg"
      >
        {t.cta}
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
      <a
        href="#how-it-works"
        class="inline-flex items-center gap-2 rounded-xl border border-gray-200 bg-white px-8 py-3.5 text-base font-semibold text-gray-700 shadow-xs transition hover:border-gray-300 hover:bg-gray-50"
      >
        {t.ctaSecondary}
      </a>
    </div>

    <!-- Stats -->
    <div class="mx-auto mt-16 grid max-w-lg grid-cols-3 gap-8 border-t border-gray-200 pt-10">
      <div>
        <div class="font-display text-3xl font-semibold text-brand-500">{t.stat1Value}</div>
        <div class="mt-1 text-sm text-gray-500">{t.stat1Label}</div>
      </div>
      <div>
        <div class="font-display text-3xl font-semibold text-brand-500">{t.stat2Value}</div>
        <div class="mt-1 text-sm text-gray-500">{t.stat2Label}</div>
      </div>
      <div>
        <div class="font-display text-3xl font-semibold text-brand-500">{t.stat3Value}</div>
        <div class="mt-1 text-sm text-gray-500">{t.stat3Label}</div>
      </div>
    </div>
  </div>
</section>
