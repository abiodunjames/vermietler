---
interface Props {
  title: string;
  description: string;
  date: Date;
  author: string;
  slug: string;
  tags: string[];
  lang?: string;
}

const { title, description, date, author, slug, tags, lang = "en" } = Astro.props;
const href = lang === "de" ? `/de/blog/${slug}` : `/blog/${slug}`;
const formattedDate = date.toLocaleDateString(lang === "de" ? "de-DE" : "en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="group">
  <a href={href} class="block rounded-2xl border border-gray-200 bg-white p-6 shadow-xs transition hover:border-brand-200 hover:shadow-md">
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="rounded-full bg-brand-50 px-2.5 py-0.5 text-xs font-medium text-brand-700">
          {tag}
        </span>
      ))}
    </div>
    <h2 class="mt-3 text-lg font-semibold text-gray-900 transition group-hover:text-brand-500">
      {title}
    </h2>
    <p class="mt-2 text-sm leading-relaxed text-gray-500 line-clamp-2">
      {description}
    </p>
    <div class="mt-4 flex items-center gap-3 text-xs text-gray-400">
      <span>{author}</span>
      <span class="h-1 w-1 rounded-full bg-gray-300"></span>
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </div>
  </a>
</article>
