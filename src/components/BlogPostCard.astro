---
interface Props {
  title: string;
  description: string;
  date: Date;
  author: string;
  slug: string;
  tags: string[];
  lang?: string;
  featured?: boolean;
}

const { title, description, date, author, slug, tags, lang = "en", featured = false } = Astro.props;
const href = lang === "de" ? `/de/blog/${slug}` : `/blog/${slug}`;
const formattedDate = date.toLocaleDateString(lang === "de" ? "de-DE" : "en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
const authorInitials = author.split(" ").map(w => w[0]).join("").slice(0, 2).toUpperCase();

// Estimate reading time from title + description length (rough proxy)
const wordCount = (title + " " + description).split(/\s+/).length;
const readTime = Math.max(3, Math.round(wordCount / 30));
const readLabel = lang === "de" ? `${readTime} Min.` : `${readTime} min`;

// Category color based on first tag
const tagColors: Record<string, { bg: string; text: string; strip: string }> = {
  default: { bg: "bg-brand-50", text: "text-brand-700", strip: "from-blue-800 to-brand-500" },
  Mietrecht: { bg: "bg-red-50", text: "text-red-700", strip: "from-red-900 to-red-600" },
  Mietpreisbremse: { bg: "bg-brand-50", text: "text-brand-700", strip: "from-blue-800 to-brand-500" },
  Hausgeld: { bg: "bg-amber-50", text: "text-amber-700", strip: "from-amber-800 to-amber-500" },
  Nebenkosten: { bg: "bg-amber-50", text: "text-amber-700", strip: "from-amber-800 to-amber-500" },
  financing: { bg: "bg-emerald-50", text: "text-emerald-700", strip: "from-emerald-800 to-emerald-500" },
  Finanzierung: { bg: "bg-emerald-50", text: "text-emerald-700", strip: "from-emerald-800 to-emerald-500" },
  mortgage: { bg: "bg-emerald-50", text: "text-emerald-700", strip: "from-emerald-800 to-emerald-500" },
  Eigenkapital: { bg: "bg-emerald-50", text: "text-emerald-700", strip: "from-emerald-800 to-emerald-500" },
  KfW: { bg: "bg-emerald-50", text: "text-emerald-700", strip: "from-emerald-800 to-emerald-500" },
  "WEG-Verwaltung": { bg: "bg-purple-50", text: "text-purple-700", strip: "from-purple-900 to-purple-600" },
  Sondereigentumsverwaltung: { bg: "bg-purple-50", text: "text-purple-700", strip: "from-purple-900 to-purple-600" },
  SEV: { bg: "bg-purple-50", text: "text-purple-700", strip: "from-purple-900 to-purple-600" },
  Hausbesichtigung: { bg: "bg-cyan-50", text: "text-cyan-700", strip: "from-cyan-800 to-cyan-500" },
  Grundsteuer: { bg: "bg-amber-50", text: "text-amber-700", strip: "from-amber-800 to-amber-500" },
  Maklerprovision: { bg: "bg-brand-50", text: "text-brand-700", strip: "from-blue-800 to-brand-500" },
};
const firstTag = tags[0] || "";
const colors = tagColors[firstTag] || tagColors.default;
---

<article class="group">
  <a href={href} class:list={[
    "post-card block overflow-hidden rounded-xl border border-gray-200 bg-white shadow-xs transition-all duration-200 hover:-translate-y-[2px] hover:shadow-md hover:border-brand-200",
    featured ? "sm:col-span-2" : ""
  ]}>
    {/* Color strip header */}
    <div class:list={["relative h-[120px] bg-gradient-to-br", colors.strip, featured ? "h-[160px]" : ""]}>
      <div class="absolute inset-0 opacity-[0.08]" style="background-image:url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E&quot;);background-repeat:repeat;"></div>
      {/* Category badge on strip */}
      <div class="absolute bottom-3 left-4">
        <span class:list={["inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[11px] font-semibold", colors.bg, colors.text]}>
          {firstTag}
        </span>
      </div>
    </div>

    {/* Card body */}
    <div class:list={["p-5", featured ? "p-6" : ""]}>
      <h2 class:list={[
        "font-display font-semibold leading-snug tracking-tight text-gray-900 transition group-hover:text-brand-600",
        featured ? "text-xl" : "text-[15px]",
      ]} style="letter-spacing:-0.01em;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
        {title}
      </h2>
      <p class:list={[
        "mt-2 text-gray-500 leading-relaxed",
        featured ? "text-sm line-clamp-3" : "text-[13px] line-clamp-2",
      ]}>
        {description}
      </p>
    </div>

    {/* Card footer */}
    <div class="flex items-center justify-between border-t border-gray-100 px-5 py-3">
      <div class="flex items-center gap-2">
        <div class="flex h-6 w-6 items-center justify-center rounded-full bg-brand-100 font-display text-[9px] font-bold text-brand-700">
          {authorInitials}
        </div>
        <span class="text-xs font-medium text-gray-700">{author}</span>
      </div>
      <div class="flex items-center gap-3 text-[11px] text-gray-400">
        <span>{formattedDate}</span>
        <span class="flex items-center gap-1">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {readLabel}
        </span>
      </div>
    </div>
  </a>
</article>
