---
interface Props {
  lang?: "en" | "de";
}

const { lang = "en" } = Astro.props;

/**
 * Google Forms integration. Pure HTML form, no React, no client framework.
 *
 * The trick: the form's <input> elements use the Google Forms `entry.NNNN` IDs
 * directly as their `name` attribute. The vanilla JS submit handler builds a
 * FormData from the form, POSTs to Google Forms with `mode: "no-cors"`, and
 * swaps the form for a success message via DOM manipulation.
 */
const GOOGLE_FORM_URL =
  "https://docs.google.com/forms/d/e/1FAIpQLScHcJlWZRXDs6RbxRDc44HUVVKgBSZWBQs-H28g7nWetaWpRQ/formResponse";

const ENTRY = {
  fullName: "entry.2085848003",
  email: "entry.741940622",
  phone: "entry.1498462560",
  units: "entry.595479651",
  preferredTime: "entry.295316919",
  message: "entry.312389568",
};

const t = {
  en: {
    fullName: "Full name",
    email: "Work email",
    phone: "Phone (optional)",
    units: "Number of rental units",
    unitsPlaceholder: "e.g., 3",
    preferredTime: "Preferred contact time",
    message: "What would you like to see in the demo?",
    messagePlaceholder: "Tell us about your portfolio and what matters most to you. Optional.",
    submit: "Request a demo",
    submitting: "Sending...",
    privacy: "By submitting, you agree to our",
    privacyLink: "/privacy",
    privacyLinkText: "privacy policy",
    privacyEnd: ". We will respond within one business day.",
    successTitle: "Thanks, we have your request",
    successBody:
      "We will reach out within one business day to schedule a 30-minute demo. Check your spam folder if you do not see our reply.",
    errorTitle: "Something went wrong",
    errorBody: "Please try again or email us directly at info@vermietler.com.",
    timeOptions: [
      "Mornings (9:00 to 12:00 CET)",
      "Afternoons (13:00 to 17:00 CET)",
      "Evenings (18:00 to 20:00 CET)",
      "I am flexible",
    ],
  },
  de: {
    fullName: "Vollständiger Name",
    email: "Geschäftliche E-Mail",
    phone: "Telefon (optional)",
    units: "Anzahl Mieteinheiten",
    unitsPlaceholder: "z.B. 3",
    preferredTime: "Gewünschte Kontaktzeit",
    message: "Was möchten Sie in der Demo sehen?",
    messagePlaceholder: "Erzählen Sie uns von Ihrem Portfolio und was Ihnen besonders wichtig ist. Optional.",
    submit: "Demo anfragen",
    submitting: "Wird gesendet...",
    privacy: "Mit der Anfrage stimmen Sie unserer",
    privacyLink: "/de/datenschutz",
    privacyLinkText: "Datenschutzerklärung",
    privacyEnd: " zu. Wir antworten innerhalb eines Werktags.",
    successTitle: "Danke, Ihre Anfrage ist eingegangen",
    successBody:
      "Wir melden uns innerhalb eines Werktags, um einen 30-minütigen Demo-Termin zu vereinbaren. Prüfen Sie ggf. den Spam-Ordner.",
    errorTitle: "Etwas ist schiefgelaufen",
    errorBody: "Bitte versuchen Sie es erneut oder schreiben Sie uns direkt an info@vermietler.com.",
    timeOptions: [
      "Vormittags (9:00 bis 12:00 MEZ)",
      "Nachmittags (13:00 bis 17:00 MEZ)",
      "Abends (18:00 bis 20:00 MEZ)",
      "Ich bin flexibel",
    ],
  },
}[lang]!;

const inputCls =
  "w-full rounded-lg border-[1.5px] border-gray-200 bg-white px-3.5 py-2.5 text-sm text-gray-900 outline-none transition focus:border-brand-400 focus:ring-4 focus:ring-brand-500/10";
---

<div data-demo-root data-lang={lang}>
  <form id="demo-form" class="space-y-4" novalidate>
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label class="mb-1 block text-xs font-medium text-gray-700" for="df-name">{t.fullName}</label>
        <input id="df-name" name={ENTRY.fullName} type="text" required class={inputCls} />
      </div>
      <div>
        <label class="mb-1 block text-xs font-medium text-gray-700" for="df-email">{t.email}</label>
        <input id="df-email" name={ENTRY.email} type="email" required class={inputCls} />
      </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label class="mb-1 block text-xs font-medium text-gray-700" for="df-phone">{t.phone}</label>
        <input id="df-phone" name={ENTRY.phone} type="tel" class={inputCls} />
      </div>
      <div>
        <label class="mb-1 block text-xs font-medium text-gray-700" for="df-units">{t.units}</label>
        <input
          id="df-units"
          name={ENTRY.units}
          type="number"
          min="1"
          required
          placeholder={t.unitsPlaceholder}
          class={inputCls}
        />
      </div>
    </div>

    <div>
      <label class="mb-1 block text-xs font-medium text-gray-700" for="df-time">{t.preferredTime}</label>
      <select id="df-time" name={ENTRY.preferredTime} class={`${inputCls} appearance-none`}>
        {t.timeOptions.map((opt) => <option value={opt}>{opt}</option>)}
      </select>
    </div>

    <div>
      <label class="mb-1 block text-xs font-medium text-gray-700" for="df-msg">{t.message}</label>
      <textarea
        id="df-msg"
        name={ENTRY.message}
        rows="4"
        placeholder={t.messagePlaceholder}
        class={inputCls}
      ></textarea>
    </div>

    <div data-demo-error hidden class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">
      <p class="font-semibold">{t.errorTitle}</p>
      <p class="mt-0.5">{t.errorBody}</p>
    </div>

    <button
      type="submit"
      data-demo-submit
      data-label-default={t.submit}
      data-label-submitting={t.submitting}
      class="w-full rounded-lg bg-brand-500 px-5 py-3 text-sm font-semibold text-white shadow-xs transition hover:bg-brand-600 disabled:opacity-60"
    >
      {t.submit}
    </button>

    <p class="text-center text-[11px] text-gray-400">
      {t.privacy}{" "}
      <a href={t.privacyLink} class="underline hover:text-gray-600">{t.privacyLinkText}</a>{t.privacyEnd}
    </p>
  </form>

  <div data-demo-success hidden class="rounded-2xl border border-emerald-200 bg-emerald-50 p-8 text-center">
    <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </div>
    <h2 class="font-display text-xl font-semibold text-emerald-800">{t.successTitle}</h2>
    <p class="mx-auto mt-2 max-w-md text-sm text-emerald-700/80">{t.successBody}</p>
  </div>
</div>

<script is:inline define:vars={{ url: GOOGLE_FORM_URL, lang }}>
  (function () {
    const root = document.querySelector("[data-demo-root]");
    if (!root) return;
    const form = root.querySelector("#demo-form");
    const submitBtn = root.querySelector("[data-demo-submit]");
    const successEl = root.querySelector("[data-demo-success]");
    const errorEl = root.querySelector("[data-demo-error]");
    if (!form || !submitBtn || !successEl || !errorEl) return;

    const labelDefault = submitBtn.getAttribute("data-label-default") || "";
    const labelSubmitting = submitBtn.getAttribute("data-label-submitting") || "";

    form.addEventListener("submit", async function (e) {
      e.preventDefault();
      if (submitBtn.disabled) return;

      submitBtn.disabled = true;
      submitBtn.textContent = labelSubmitting;
      errorEl.hidden = true;

      const data = new FormData(form);

      try {
        await fetch(url, { method: "POST", mode: "no-cors", body: data });
        // Fire PostHog event if loaded.
        if (window.posthog && typeof window.posthog.capture === "function") {
          window.posthog.capture("demo_request_submitted", {
            units: data.get("entry.595479651"),
            preferred_time: data.get("entry.295316919"),
            has_message: !!String(data.get("entry.312389568") || "").length,
            lang: lang,
          });
        }
        form.hidden = true;
        successEl.hidden = false;
        // Smooth scroll the success card into view if the form was below the fold.
        successEl.scrollIntoView({ behavior: "smooth", block: "center" });
      } catch (err) {
        errorEl.hidden = false;
        submitBtn.disabled = false;
        submitBtn.textContent = labelDefault;
      }
    });
  })();
</script>
