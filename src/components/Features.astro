  de: {
    eyebrow: "Alles was Sie brauchen",
    headline: "Eine Plattform für Ihr gesamtes Portfolio",
    sub: "Von der Erfassung Ihrer ersten Immobilie bis zur Nebenkostenabrechnung - Vermietler erledigt alles.",
