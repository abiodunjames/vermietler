      {
        icon: "building",
        title: "Property & unit management",
        description: "Organize properties, units, equipment, and photos in a clear hierarchy. Track vacancy and occupancy at a glance.",
      },
      {
        icon: "bank",
        title: "Banking & rent tracking",
        description: "Connect bank accounts, auto-import transactions, and reconcile rent payments. Know who paid and who didn't, instantly.",
      },
      {
        icon: "receipt",
        title: "AI receipt capture",
        description: "Snap a photo of any receipt or invoice. Our AI extracts vendor, amount, date, and category automatically.",
      },
      {
        icon: "statement",
        title: "Nebenkosten statements",
        description: "Generate operating and heating cost statements with a guided wizard. Allocation keys, proration, and PDF export built in.",
      },
      {
        icon: "folder",
        title: "Document vault",
        description: "Upload, tag, and search documents by property, unit, vendor, or period. Share securely with tenants via the portal.",
      },
      {
        icon: "message",
        title: "Tenant communication",
        description: "Message tenants directly from the platform. Use templates for rent reminders, appointments, and meter readings.",
