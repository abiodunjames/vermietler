      {
        icon: "building",
        title: "Immobilien- & Einheitenverwaltung",
        description: "Organisieren Sie Immobilien, Einheiten, Ausstattung und Fotos in einer klaren Hierarchie. Leerstand und Belegung auf einen Blick.",
      },
      {
        icon: "bank",
        title: "Banking & Mietverfolgung",
        description: "Bankkonten verbinden, Transaktionen automatisch importieren und Mietzahlungen abgleichen. Sofort wissen, wer bezahlt hat.",
      },
      {
        icon: "receipt",
        title: "KI-Belegerfassung",
        description: "Fotografieren Sie Belege oder Rechnungen. Unsere KI extrahiert Lieferant, Betrag, Datum und Kategorie automatisch.",
      },
      {
        icon: "statement",
        title: "Nebenkostenabrechnung",
        description: "Betriebs- und Heizkostenabrechnungen per Assistent erstellen. Umlageschlüssel, Proratierung und PDF-Export inklusive.",
      },
      {
        icon: "folder",
        title: "Dokumenten-Tresor",
        description: "Dokumente hochladen, taggen und nach Immobilie, Einheit, Lieferant oder Zeitraum suchen. Sicher mit Mietern teilen.",
      },
      {
        icon: "message",
        title: "Mieterkommunikation",
        description: "Nachrichten direkt aus der Plattform senden. Vorlagen für Mietmahnungen, Termine und Zählerstandsabfragen.",
      },
      {
        icon: "meter",
        title: "Zählerstände",
        description: "Wasser-, Heizungs- und Stromverbrauch pro Einheit erfassen. Import per CSV oder manuelle Eingabe.",
      },
      {
        icon: "recurring",
        title: "Wiederkehrende Ausgaben",
        description: "Versicherungen, Wartungsverträge oder Grundsteuer als wiederkehrende Kosten anlegen. Automatisch monatlich erzeugt und in die Abrechnung übernommen.",
      },
      {
        icon: "chart",
        title: "Cashflow-Diagramme",
        description: "Mieteinnahmen, Ausgaben und Netto-Cashflow auf einen Blick. Nach Immobilie, Einheit oder Zeitraum filtern mit interaktiven Diagrammen.",
      },
      {
        icon: "damage",
        title: "Schadensmeldungen",
        description: "Mieter melden Schäden mit Fotos über das Portal. Status verfolgen, Priorität zuweisen und eine vollständige Reparaturhistorie führen.",
      },
      {
        icon: "contacts",
        title: "Handwerker & Kontakte",
        description: "Verzeichnis für Klempner, Elektriker und Dienstleister. Kontakte mit Immobilien verknüpfen für schnellen Zugriff bei Problemen.",
      },
      {
        icon: "shield",
        title: "DSGVO-konform",
        description: "Entwickelt nach deutschem Datenschutzrecht. Audit-Logs, Datenexport, Aufbewahrungsrichtlinien und Verschlüsselung.",
      },
    ],
  },
