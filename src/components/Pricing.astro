---
interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;

const t = {
  en: {
    eyebrow: "Pricing",
    headline: "Simple, transparent pricing",
    sub: "Start free, upgrade when you grow. No credit card required.",
    mostPopular: "Most popular",
    billedAnnually: "billed annually",
    perMonth: "/month",
    forever: "forever",
    saveAnnual: "Save ~30% with annual billing",
    plans: [
      {
        name: "Free",
        tagline: "Starter",
        price: "€0",
        period: "forever",
        description: "For single-unit landlords getting started.",
        features: [
          "1 unit · 1 property",
          "1 active lease",
          "1 bank connection",
          "200 MB document storage",
          "Full expense tracking",
          "Meter readings",
          "Cashflow dashboard",
          "1 Nebenkostenabrechnung per year",
          "5 message templates",
        ],
        cta: "Start for free",
        highlighted: false,
      },
      {
        name: "Plus",
        tagline: "For growing portfolios",
        price: "€4.90",
        period: "/month",
        priceNote: "billed annually (€58.80/year) · €6.90 monthly",
        description: "For landlords with multiple units.",
        features: [
          "10 units · 5 properties",
          "10 active leases",
          "2 bank connections",
          "2 GB document storage",
          "Unlimited Nebenkosten statements",
          "Tenant portal",
          "Letter dispatch (pay-per-use)",
          "Recurring expenses",
          "50 contacts directory",
          "Unlimited message templates",
        ],
        cta: "Upgrade to Plus",
        highlighted: true,
      },
    ],
  },
  de: {
    eyebrow: "Preise",
    headline: "Einfache, transparente Preise",
    sub: "Kostenlos starten, upgraden wenn Sie wachsen. Keine Kreditkarte erforderlich.",
    mostPopular: "Am beliebtesten",
    billedAnnually: "jährlich abgerechnet",
    perMonth: "/Monat",
    forever: "für immer",
    saveAnnual: "Spare ~30% mit jährlicher Abrechnung",
    plans: [
      {
        name: "Free",
        tagline: "Starter",
        price: "0 €",
        period: "für immer",
        description: "Für Vermieter mit einer Einheit zum Einstieg.",
        features: [
          "1 Einheit · 1 Immobilie",
          "1 aktives Mietverhältnis",
          "1 Bankverbindung",
          "200 MB Dokumentenspeicher",
          "Vollständige Ausgabenverfolgung",
          "Zählerstandserfassung",
          "Cashflow-Dashboard",
          "1 Nebenkostenabrechnung pro Jahr",
          "5 Nachrichtenvorlagen",
        ],
        cta: "Kostenlos starten",
        highlighted: false,
      },
      {
        name: "Plus",
        tagline: "Für wachsende Portfolios",
        price: "4,90 €",
        period: "/Monat",
        priceNote: "jährlich abgerechnet (58,80 €/Jahr) · 6,90 € monatlich",
        description: "Für Vermieter mit mehreren Einheiten.",
        features: [
          "10 Einheiten · 5 Immobilien",
          "10 aktive Mietverhältnisse",
          "2 Bankverbindungen",
          "2 GB Dokumentenspeicher",
          "Unbegrenzte Nebenkostenabrechnungen",
          "Mieterportal",
          "Briefversand (nutzungsbasiert)",
          "Wiederkehrende Ausgaben",
          "50 Kontakte im Verzeichnis",
          "Unbegrenzte Nachrichtenvorlagen",
        ],
        cta: "Auf Plus upgraden",
        highlighted: true,
      },
    ],
  },
}[lang]!;
---

<section id="pricing" class="bg-gray-50 py-24">
  <div class="mx-auto max-w-5xl px-6">
    <div class="text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.08em] text-brand-500">{t.eyebrow}</p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl">
        {t.headline}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-500">{t.sub}</p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-2">
      {t.plans.map((plan) => (
        <div
          class:list={[
            "relative rounded-2xl border p-8 transition",
            plan.highlighted
              ? "border-brand-300 bg-white shadow-lg ring-1 ring-brand-200"
              : "border-gray-200 bg-white shadow-xs hover:shadow-sm",
          ]}
        >
          {plan.highlighted && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-500 px-4 py-1 text-xs font-semibold text-white">
              {t.mostPopular}
            </div>
          )}

          <div>
            <h3 class="text-lg font-semibold text-gray-900">{plan.name}</h3>
            <p class="text-sm text-gray-400">{plan.tagline}</p>
          </div>

          <div class="mt-4 flex items-baseline">
            <span class="font-display text-4xl font-semibold text-gray-900">{plan.price}</span>
            {plan.period && <span class="ml-1 text-gray-500">{plan.period}</span>}
          </div>

          {plan.priceNote && (
            <p class="mt-1 text-xs text-gray-400">{plan.priceNote}</p>
          )}

          <p class="mt-3 text-sm text-gray-500">{plan.description}</p>

          <a
            href="#"
            class:list={[
              "mt-6 block w-full rounded-lg py-3 text-center text-sm font-semibold transition",
              plan.highlighted
                ? "bg-brand-500 text-white shadow-xs hover:bg-brand-600"
                : "border border-gray-200 text-gray-700 hover:bg-gray-50",
            ]}
          >
            {plan.cta}
          </a>

          <ul class="mt-8 space-y-3">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm text-gray-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
