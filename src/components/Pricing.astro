---
interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;

const t = {
  en: {
    eyebrow: "Pricing",
    headline: "Simple, transparent pricing",
    sub: "Start free, upgrade when you grow. No hidden fees.",
    mostPopular: "Most popular",
    plans: [
      {
        name: "Starter",
        price: "Free",
        period: "",
        description: "Perfect for getting started with 1-2 properties.",
        features: [
          "Up to 2 properties",
          "Up to 5 units",
          "Document upload & storage",
          "Meter readings",
          "Basic reporting",
        ],
        cta: "Get started",
        highlighted: false,
      },
      {
        name: "Professional",
        price: "\u20AC19",
        period: "/month",
        description: "For landlords who want the full power of automation.",
        features: [
          "Unlimited properties & units",
          "Bank account integration",
          "Auto rent reconciliation",
          "AI receipt capture",
          "Nebenkosten statements",
          "Tenant portal",
          "Document sharing",
          "Email communication",
          "Priority support",
        ],
        cta: "Start free trial",
        highlighted: true,
      },
      {
        name: "Enterprise",
        price: "Custom",
        period: "",
        description: "For property managers and larger portfolios.",
        features: [
          "Everything in Professional",
          "Multi-user access & roles",
          "DATEV export",
          "API access",
          "Dedicated support",
          "Custom integrations",
        ],
        cta: "Contact us",
        highlighted: false,
      },
    ],
  },
  de: {
    eyebrow: "Preise",
    headline: "Einfache, transparente Preise",
    sub: "Kostenlos starten, upgraden wenn Sie wachsen. Keine versteckten Kosten.",
    mostPopular: "Am beliebtesten",
    plans: [
      {
        name: "Starter",
        price: "Kostenlos",
        period: "",
        description: "Perfekt zum Einstieg mit 1-2 Immobilien.",
        features: [
          "Bis zu 2 Immobilien",
          "Bis zu 5 Einheiten",
          "Dokumenten-Upload & Speicher",
          "Zählerstandserfassung",
          "Basis-Berichte",
        ],
        cta: "Jetzt starten",
        highlighted: false,
      },
      {
        name: "Professional",
        price: "\u20AC19",
        period: "/Monat",
        description: "Für Vermieter, die volle Automatisierung wollen.",
        features: [
          "Unbegrenzte Immobilien & Einheiten",
          "Bankkonten-Integration",
          "Auto-Mietabgleich",
          "KI-Belegerfassung",
          "Nebenkostenabrechnung",
          "Mieterportal",
          "Dokumentenfreigabe",
          "E-Mail-Kommunikation",
          "Prioritäts-Support",
        ],
        cta: "Kostenlos testen",
        highlighted: true,
      },
      {
        name: "Enterprise",
        price: "Individuell",
        period: "",
        description: "Für Hausverwaltungen und größere Portfolios.",
        features: [
          "Alles aus Professional",
          "Mehrbenutzer & Rollen",
          "DATEV-Export",
          "API-Zugang",
          "Dedizierter Support",
          "Individuelle Integrationen",
        ],
        cta: "Kontaktieren Sie uns",
        highlighted: false,
      },
    ],
  },
}[lang]!;
---

<section id="pricing" class="bg-gray-50 py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.08em] text-brand-500">{t.eyebrow}</p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl">
        {t.headline}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-500">{t.sub}</p>
    </div>

    <div class="mt-16 grid gap-8 lg:grid-cols-3">
      {t.plans.map((plan) => (
        <div
          class:list={[
            "relative rounded-2xl border p-8 transition",
            plan.highlighted
              ? "border-brand-300 bg-white shadow-lg ring-1 ring-brand-200"
              : "border-gray-200 bg-white shadow-xs hover:shadow-sm",
          ]}
        >
          {plan.highlighted && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-500 px-4 py-1 text-xs font-semibold text-white">
              {t.mostPopular}
            </div>
          )}

          <h3 class="text-lg font-semibold text-gray-900">{plan.name}</h3>

          <div class="mt-4 flex items-baseline">
            <span class="font-display text-4xl font-semibold text-gray-900">{plan.price}</span>
            {plan.period && <span class="ml-1 text-gray-500">{plan.period}</span>}
          </div>

          <p class="mt-3 text-sm text-gray-500">{plan.description}</p>

          <a
            href="#"
            class:list={[
              "mt-6 block w-full rounded-lg py-3 text-center text-sm font-semibold transition",
              plan.highlighted
                ? "bg-brand-500 text-white shadow-xs hover:bg-brand-600"
                : "border border-gray-200 text-gray-700 hover:bg-gray-50",
            ]}
          >
            {plan.cta}
          </a>

          <ul class="mt-8 space-y-3">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm text-gray-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
