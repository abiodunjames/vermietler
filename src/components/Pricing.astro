---
interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;

const t = {
  en: {
    eyebrow: "Pricing",
    headline: "Pay per unit. First unit free.",
    sub: "€10/month per additional unit, VAT included. No annual lock-in, no credit card to get started.",
    mostPopular: "For growing portfolios",
    perMonth: "/month",
    foreverFree: "Free forever",
    notes: [
      "VAT inclusive — the price you see is the price you pay",
      "Cancel anytime from the billing page",
      "No setup fees, no hidden costs",
    ],
    plans: [
      {
        name: "Free tier",
        tagline: "For your first rental unit",
        price: "€0",
        period: "/month",
        priceNote: "Free forever · no card required",
        description: "Everything you need to manage one rental unit.",
        features: [
          "1 rental unit",
          "Unlimited properties & portfolios",
          "Tenants, leases & rent tracking",
          "Operating cost statements (Nebenkostenabrechnung)",
          "Expense tracking & AI receipt capture",
          "Meter readings (water, heating, electricity)",
          "Document vault with tenant sharing",
          "Tenant portal & messaging",
          "Damage reports with photos",
          "Handyman & service contacts directory",
          "Cashflow, yield & tax (Anlage V) reports",
          "Letter dispatch (pay-per-use)",
          "DE / EN · GDPR compliant",
        ],
        cta: "Start for free",
        cta_href: "https://app.vermietler.com/signup",
        highlighted: false,
      },
      {
        name: "Per-unit subscription",
        tagline: "For landlords with multiple units",
        price: "€10",
        period: "/unit / month",
        priceNote: "Billed monthly · cancel anytime",
        description:
          "Everything in Free, plus bank connection and unlimited units. First unit always stays free.",
        features: [
          "Everything in Free, and:",
          "Bank connection & automatic rent reconciliation",
          "Unlimited rental units",
          "Quantity adjusts automatically when you add or remove units",
          "Single Plus: unlock bank connection on a single unit too",
        ],
        cta: "Get started",
        cta_href: "https://app.vermietler.com/signup",
        highlighted: true,
      },
      {
        name: "Full service",
        tagline: "We handle the property — you collect the rent",
        price: "Custom",
        period: "",
        priceNote: "Quoted per portfolio · typically % of gross rent",
        description:
          "End-to-end property management. We deal with tenants, repairs, statements and paperwork so you don't have to.",
        features: [
          "Dedicated property manager",
          "Tenant communication & 24/7 hotline",
          "Rent collection & dunning (Mahnwesen)",
          "Repair coordination with vetted tradespeople",
          "Annual Nebenkostenabrechnung delivered to tenants",
          "Move-in / move-out inspections & protocols",
          "Quarterly owner reports & remittance",
          "Lease drafting & tenant screening",
          "Available in Berlin · other cities by request",
        ],
        cta: "Talk to us",
        cta_href:
          "mailto:info@vermietler.com?subject=Full%20service%20property%20management",
        highlighted: false,
      },
    ],
  },
  de: {
    eyebrow: "Preise",
    headline: "Pro Einheit zahlen. Erste Einheit kostenlos.",
    sub: "€10/Monat je weitere Einheit, inkl. MwSt. Keine jährliche Bindung, keine Kreditkarte für den Einstieg.",
    mostPopular: "Für wachsende Portfolios",
    perMonth: "/Monat",
    foreverFree: "Dauerhaft kostenlos",
    notes: [
      "Inkl. MwSt. — der angezeigte Preis ist der Endpreis",
      "Jederzeit kündbar von der Abrechnungsseite",
      "Keine Einrichtungsgebühr, keine versteckten Kosten",
    ],
    plans: [
      {
        name: "Kostenlose Stufe",
        tagline: "Für Ihre erste Mieteinheit",
        price: "0 €",
        period: "/Monat",
        priceNote: "Dauerhaft kostenlos · keine Karte erforderlich",
        description: "Alles, was Sie für die Verwaltung einer Mieteinheit benötigen.",
        features: [
          "1 Mieteinheit",
          "Unbegrenzt Immobilien & Portfolios",
          "Mieter, Mietverträge & Mietverfolgung",
          "Nebenkostenabrechnung",
          "Ausgabenverfolgung & KI-Belegerfassung",
          "Zählerstände (Wasser, Heizung, Strom)",
          "Dokumentenspeicher mit Mieterfreigabe",
          "Mieterportal & Nachrichten",
          "Schadensmeldungen mit Fotos",
          "Handwerker- & Dienstleisterverzeichnis",
          "Cashflow-, Rendite- & Anlage-V-Berichte",
          "Briefversand (nutzungsbasiert)",
          "DE / EN · DSGVO-konform",
        ],
        cta: "Kostenlos starten",
        cta_href: "https://app.vermietler.com/signup",
        highlighted: false,
      },
      {
        name: "Abonnement pro Einheit",
        tagline: "Für Vermieter mit mehreren Einheiten",
        price: "10 €",
        period: "/Einheit / Monat",
        priceNote: "Monatlich abgerechnet · jederzeit kündbar",
        description:
          "Alles aus Kostenlos, plus Bankverbindung und unbegrenzte Einheiten. Die erste Einheit bleibt immer kostenlos.",
        features: [
          "Alles aus Kostenlos, und:",
          "Bankverbindung & automatischer Mietabgleich",
          "Unbegrenzte Mieteinheiten",
          "Menge passt sich automatisch an Hinzufügen/Entfernen an",
          "Single Plus: Bankverbindung auch für eine einzige Einheit freischalten",
        ],
        cta: "Jetzt starten",
        cta_href: "https://app.vermietler.com/signup",
        highlighted: true,
      },
      {
        name: "Vollverwaltung",
        tagline: "Wir verwalten — Sie kassieren die Miete",
        price: "Auf Anfrage",
        period: "",
        priceNote: "Pro Portfolio kalkuliert · meist % der Bruttomiete",
        description:
          "Komplette Immobilienverwaltung. Wir kümmern uns um Mieter, Reparaturen, Abrechnungen und Schriftverkehr — Sie müssen nichts tun.",
        features: [
          "Persönlicher Immobilienverwalter",
          "Mieterkommunikation & 24/7-Hotline",
          "Mieteinzug & Mahnwesen",
          "Reparatur-Koordination mit geprüften Handwerkern",
          "Jährliche Nebenkostenabrechnung an Mieter",
          "Ein- & Auszugsprotokolle und Wohnungsabnahmen",
          "Vierteljährliche Eigentümerberichte & Überweisungen",
          "Mietvertragserstellung & Mieterprüfung",
          "Verfügbar in Berlin · weitere Städte auf Anfrage",
        ],
        cta: "Kontaktieren Sie uns",
        cta_href:
          "mailto:info@vermietler.com?subject=Vollverwaltung%20Anfrage",
        highlighted: false,
      },
    ],
  },
}[lang]!;
---

<section id="pricing" class="bg-gray-50 py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.08em] text-brand-500">{t.eyebrow}</p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-gray-900 sm:text-4xl">
        {t.headline}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-500">{t.sub}</p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {t.plans.map((plan) => (
        <div
          class:list={[
            "relative flex flex-col rounded-2xl border p-8 transition",
            plan.highlighted
              ? "border-brand-300 bg-white shadow-lg ring-1 ring-brand-200"
              : "border-gray-200 bg-white shadow-xs hover:shadow-sm",
          ]}
        >
          {plan.highlighted && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-500 px-4 py-1 text-xs font-semibold text-white">
              {t.mostPopular}
            </div>
          )}

          <div>
            <h3 class="text-lg font-semibold text-gray-900">{plan.name}</h3>
            <p class="text-sm text-gray-400">{plan.tagline}</p>
          </div>

          <div class="mt-4 flex items-baseline">
            <span class="font-display text-4xl font-semibold text-gray-900">{plan.price}</span>
            {plan.period && <span class="ml-1 text-gray-500">{plan.period}</span>}
          </div>

          {plan.priceNote && (
            <p class="mt-1 text-xs text-gray-400">{plan.priceNote}</p>
          )}

          <p class="mt-3 text-sm text-gray-500">{plan.description}</p>

          <a
            href={plan.cta_href}
            class:list={[
              "mt-6 block w-full rounded-lg py-3 text-center text-sm font-semibold transition",
              plan.highlighted
                ? "bg-brand-500 text-white shadow-xs hover:bg-brand-600"
                : "border border-gray-200 text-gray-700 hover:bg-gray-50",
            ]}
          >
            {plan.cta}
          </a>

          <ul class="mt-8 space-y-3">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm text-gray-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <ul class="mx-auto mt-12 grid max-w-3xl gap-3 text-sm text-gray-500 md:grid-cols-3">
      {t.notes.map((note) => (
        <li class="flex items-start gap-2">
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
          {note}
        </li>
      ))}
    </ul>
  </div>
</section>
