---

<!-- ── Hero ── -->
<section class="landing-hero relative min-h-screen flex flex-col overflow-hidden" id="home">
  <div class="landing-hero-glow"></div>
  <div class="landing-hero-glow-2"></div>

  <div class="relative z-10 flex flex-1 flex-col items-center justify-center px-8 pt-36 pb-20 text-center lg:pt-44 lg:pb-32">
    <div class="mx-auto max-w-[900px]">
      <!-- Badge -->
      <div class="mb-7 inline-flex items-center gap-2 rounded-full border border-brand-400/30 bg-brand-500/15 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-300 backdrop-blur-sm">
        <span class="relative flex h-1.5 w-1.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-400 opacity-75"></span>
          <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-brand-400"></span>
        </span>
        {t.heroBadge}
      </div>

      <!-- Title -->
      <h1 class="font-display text-[clamp(38px,5.5vw,72px)] font-bold leading-[1.08] tracking-tight text-white" style="letter-spacing:-0.04em">
        {t.heroTitle1}<br />
        <span class="relative inline-block">
          <span class="bg-gradient-to-r from-brand-400 to-brand-300 bg-clip-text text-transparent">{t.heroTitle2}</span>
          <span class="absolute bottom-[-4px] left-0 right-0 h-[3px] rounded-full bg-gradient-to-r from-brand-400 to-brand-300 opacity-70"></span>
        </span>
      </h1>

      <!-- Subtitle -->
      <p class="mx-auto mt-6 max-w-[580px] text-[clamp(16px,1.8vw,20px)] leading-relaxed text-white/60" set:html={t.heroSub} />

      <!-- Waitlist form -->
      <div class="mt-10" id="waitlist">
        <form class="landing-waitlist-form mx-auto flex max-w-[460px] items-center gap-0 rounded-full border-[1.5px] border-white/20 bg-white/8 p-1.5 pl-5 backdrop-blur-md" id="hero-form">
          <input
            type="email"
            id="hero-email"
            required
            placeholder={t.emailPlaceholder}
            class="min-w-0 flex-1 border-none bg-transparent text-sm text-white outline-none placeholder:text-white/40"
          />
          <button type="submit" class="flex-shrink-0 rounded-full bg-brand-500 px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-400 hover:text-[#1e2d45]">
            {t.heroCta}
          </button>
        </form>
        <p class="mt-3.5 flex items-center justify-center gap-1.5 text-xs text-white/35">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          {t.heroNote}
        </p>
      </div>

      <!-- Success message -->
      <div class="hidden mx-auto max-w-[460px] items-center gap-3 rounded-2xl border border-emerald-500/30 bg-emerald-500/15 px-5 py-4" id="hero-success">
        <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-emerald-500/25 text-emerald-400">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="text-left">
          <div class="text-sm font-semibold text-white">{t.successTitle}</div>
          <div class="text-xs text-white/50">{t.successSub}</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── Features ── -->
<section class="bg-gray-50 px-8 py-24" id="features">
  <div class="mx-auto max-w-[1160px]">
    <div class="mb-14 text-center">
      <div class="mb-3 inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-widest text-brand-500">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        {t.featEyebrow}
      </div>
      <h2 class="font-display text-[clamp(28px,3vw,44px)] font-bold tracking-tight text-[#1e2d45]" style="letter-spacing:-0.03em;line-height:1.15">{t.featTitle}</h2>
      <p class="mx-auto mt-4 max-w-[560px] text-lg text-gray-500">{t.featSub}</p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {t.features.map((feat, i) => (
        <div class:list={[
          "feature-card group relative overflow-hidden rounded-3xl border bg-white p-8 shadow-xs transition-all duration-200 hover:-translate-y-[3px] hover:shadow-lg",
          feat.highlight ? "border-brand-200 bg-brand-25" : "border-gray-200 hover:border-brand-200"
        ]}>
          <div class="mb-5 flex h-[52px] w-[52px] items-center justify-center rounded-2xl" style={featureIconBgs[i]}>
            <Fragment set:html={featureIcons[i]} />
          </div>
          <h3 class="font-display text-lg font-bold text-[#1e2d45]" style="letter-spacing:-0.015em">{feat.title}</h3>
          <p class="mt-2.5 text-sm leading-relaxed text-gray-500">{feat.desc}</p>
          <span class:list={[
            "mt-4 inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[11.5px] font-semibold",
            feat.tagStyle === "blue" && "bg-brand-50 text-brand-700",
            feat.tagStyle === "orange" && "bg-orange-50 text-orange-700",
            feat.tagStyle === "green" && "bg-emerald-50 text-emerald-800",
            feat.tagStyle === "gray" && "bg-gray-100 text-gray-500",
          ]}>
            {(feat.tagStyle === "blue" || feat.tagStyle === "green") && !feat.highlight && (
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            )}
            {feat.tagStyle === "orange" && (
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            )}
            {feat.tag}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── How it works ── -->
<section class="bg-white px-8 py-24" id="how">
  <div class="mx-auto max-w-[1160px]">
    <div class="max-w-[520px]">
      <div class="mb-3 inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-widest text-brand-500">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        {t.howEyebrow}
      </div>
      <h2 class="font-display text-[clamp(28px,3vw,44px)] font-bold tracking-tight text-[#1e2d45]" style="letter-spacing:-0.03em;line-height:1.15">{t.howTitle}</h2>
      <p class="mt-4 text-base text-gray-500">{t.howSub}</p>
    </div>

    <div class="mt-14 grid items-center gap-16 lg:grid-cols-2">
      <!-- Steps -->
