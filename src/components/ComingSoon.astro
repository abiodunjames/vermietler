<style is:global>
  /* ── Hero slide rotator ── */
  .hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s ease, transform 0.6s ease;
    pointer-events: none;
  }
  .hero-slide.hero-slide-active {
    position: relative;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .hero-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.3);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }
  .hero-dot:hover {
    border-color: rgba(255,255,255,0.6);
  }
  .hero-dot.hero-dot-active {
    background: #60a5fa;
    border-color: #60a5fa;
    width: 24px;
    border-radius: 999px;
  }

  /* ── Hero ── */
  .landing-hero {
    background: linear-gradient(160deg, #141f30 0%, #1e2d45 45%, #1a3560 80%, #1e4080 100%);
  }
  .landing-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(96,165,250,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(96,165,250,0.06) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }
  .landing-hero-glow {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 800px;
    height: 800px;
    background: radial-gradient(ellipse, rgba(37,99,235,0.18) 0%, transparent 65%);
    pointer-events: none;
  }
  .landing-hero-glow-2 {
    position: absolute;
    bottom: -20%;
    left: -15%;
    width: 600px;
    height: 600px;
    background: radial-gradient(ellipse, rgba(96,165,250,0.1) 0%, transparent 65%);
    pointer-events: none;
  }

  /* ── Form focus (legacy) ── */
  .landing-waitlist-form:focus-within {
    border-color: rgba(96,165,250,0.5);
    box-shadow: 0 0 0 4px rgba(37,99,235,0.12);
  }

  /* ── Feature card gradient overlay ── */
  .feature-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 60%, rgba(37,99,235,0.025));
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .feature-card:hover::before {
    opacity: 1;
  }

  /* ── How it works step states ── */
  .how-step.active .how-step-num {
    background: var(--color-brand-500);
    color: #fff;
  }
  .how-step.active .font-display {
    color: #1e2d45;
  }

  /* ── Nebenkosten section ── */
  .landing-nebk {
    background: linear-gradient(160deg, #141f30 0%, #1e2d45 60%, #1a3560 100%);
  }
  .landing-nebk::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(96,165,250,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(96,165,250,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }
  .landing-nebk-glow {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 700px;
    height: 700px;
    background: radial-gradient(ellipse, rgba(37,99,235,0.2) 0%, transparent 65%);
    pointer-events: none;
  }

  /* ── CTA section ── */
  .landing-cta {
    background: linear-gradient(160deg, #141f30 0%, #1e2d45 60%, #1a3560 100%);
  }
  .landing-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(96,165,250,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(96,165,250,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }
  .landing-cta-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(37,99,235,0.2) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ── Smooth scroll for anchor links ── */
  html {
    scroll-behavior: smooth;
  }
</style>

<script define:vars={{ formEndpoint, entryId }}>
  const FORM_ENDPOINT = formEndpoint;
  const ENTRY_ID = entryId;

  function handleSubmit(formEl, successEl) {
    if (!formEl) return;
    formEl.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = formEl.querySelector('input[type="email"]');
      const email = input?.value.trim();
      if (!email) return;

      const btn = formEl.querySelector('button[type="submit"]');
      if (btn) btn.disabled = true;

      try {
        const body = new URLSearchParams();
        body.append(ENTRY_ID, email);
        await fetch(FORM_ENDPOINT, {
          method: 'POST',
          mode: 'no-cors',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: body.toString(),
        });

        // Track signup
        if (window.posthog) {
          window.posthog.capture('email_signup', { location: successEl ? 'hero' : 'cta' });
          window.posthog.identify(email, { email });
        }

        if (successEl) {
          formEl.style.display = 'none';
          const note = formEl.nextElementSibling;
          if (note?.tagName === 'P') note.style.display = 'none';
          successEl.style.display = 'flex';
        } else {
          if (btn) {
            btn.textContent = "\u2713";
            btn.style.background = '#059669';
          }
        }
      } catch {
        if (btn) btn.disabled = false;
      }
    });
  }

  handleSubmit(
    document.getElementById('hero-form'),
    document.getElementById('hero-success')
  );
  handleSubmit(
    document.getElementById('cta-form'),
    null
  );

  // Hero slide rotator
  (function(){
    var slides = document.querySelectorAll('.hero-slide');
    var dots = document.querySelectorAll('.hero-dot');
    if (slides.length < 2) return;
    var current = 0;
    var interval = 5000;
    var timer;

    function goTo(idx) {
      slides[current].classList.remove('hero-slide-active');
      dots[current].classList.remove('hero-dot-active');
      current = idx % slides.length;
      slides[current].classList.add('hero-slide-active');
      dots[current].classList.add('hero-dot-active');
    }

    function startAuto() {
      timer = setInterval(function(){ goTo(current + 1); }, interval);
    }

    dots.forEach(function(dot, i) {
      dot.addEventListener('click', function() {
        clearInterval(timer);
        goTo(i);
        startAuto();
      });
    });

    startAuto();
  })();

  // How it works step switching
  document.querySelectorAll('.how-step').forEach(step => {
    step.addEventListener('click', () => {
      document.querySelectorAll('.how-step').forEach(s => s.classList.remove('active'));
      step.classList.add('active');
    });
  });

  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', (e) => {
      const target = document.querySelector(a.getAttribute('href'));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
</script>
