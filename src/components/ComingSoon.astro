  <div class="pointer-events-none absolute -bottom-[22%] -left-[12%] h-[640px] w-[640px]" style="background:radial-gradient(rgba(96,165,250,0.12) 0%,transparent 65%)"></div>

  <div class="relative z-10 mx-auto max-w-[1160px] px-8 pt-36 pb-20 lg:pt-44 lg:pb-24">

    <!-- Lead copy (rotating between two messages) -->
    <div class="mx-auto mb-14 max-w-[720px] text-center">

      <div class="hero-rotator relative" style="min-height:160px">
        <!-- Slide A: Property management -->
        <div class="hero-slide hero-slide-active" data-slide="0">
          <h1 class="font-display text-[clamp(30px,3.2vw,46px)] font-bold leading-[1.1] text-white" style="letter-spacing:-0.03em">
            {lang === "de" ? "Immobilienverwaltung" : "Property management"}<br/>
            <span class="bg-gradient-to-r from-brand-400 to-brand-300 bg-clip-text text-transparent">{lang === "de" ? "für deutsche Vermieter." : "for German landlords."}</span>
          </h1>
          <p class="mx-auto mt-5 max-w-[620px] text-[17px] leading-relaxed text-white/60">
            {lang === "de"
