<!-- ── Hero v2: Financial visibility ── -->
<section class="relative overflow-hidden" id="home" style="background:linear-gradient(160deg,#141f30 0%,#1e2d45 50%,#1a3560 100%)">
  <!-- Grid pattern overlay -->
  <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(96,165,250,0.05) 1px,transparent 1px),linear-gradient(90deg,rgba(96,165,250,0.05) 1px,transparent 1px);background-size:48px 48px;"></div>
  <!-- Glow effects -->
