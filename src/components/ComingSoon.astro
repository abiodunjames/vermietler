---
interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;

const t = {
  en: {
    badge: "Coming Soon",
    headline: "Property management,",
    headlineAccent: "simplified.",
    sub: "The all-in-one platform for German landlords. Manage properties, finances, tenants, documents, and Nebenkosten statements — all in one place.",
    emailPlaceholder: "Enter your email",
    cta: "Get Early Access",
    submitting: "Sending...",
    successTitle: "You're on the list!",
    successMessage: "We'll notify you as soon as Vermietler launches.",
    errorMessage: "Something went wrong. Please try again.",
    featuresHeadline: "What's coming",
    features: [
      { icon: "building", title: "Property & unit management", description: "Organize your entire portfolio in a clear hierarchy." },
      { icon: "bank", title: "Banking & rent tracking", description: "Auto-import transactions and reconcile payments instantly." },
      { icon: "receipt", title: "AI receipt capture", description: "Snap a receipt — AI extracts vendor, amount, and category." },
      { icon: "statement", title: "Nebenkosten statements", description: "Generate operating cost statements with a guided wizard." },
      { icon: "folder", title: "Document vault", description: "Upload, tag, and share documents securely with tenants." },
      { icon: "shield", title: "DSGVO compliant", description: "Built with German privacy law in mind from day one." },
    ],
    legal: "Legal",
    privacy: "Privacy Policy",
    terms: "Terms of Service",
    imprint: "Imprint",
    social: "Connect",
    loanCalc: "Loan Calculator",
    loanCalcHref: "/hypothekenrechner",
    copyright: `© ${new Date().getFullYear()} Vermietler. All rights reserved.`,
  },
  de: {
    badge: "Demnächst verfügbar",
    headline: "Immobilienverwaltung,",
    headlineAccent: "vereinfacht.",
    sub: "Die All-in-One-Plattform für deutsche Vermieter. Verwalten Sie Immobilien, Finanzen, Mieter, Dokumente und Nebenkostenabrechnungen — alles an einem Ort.",
    emailPlaceholder: "Ihre E-Mail-Adresse",
    cta: "Frühzugang sichern",
    submitting: "Wird gesendet...",
    successTitle: "Sie sind dabei!",
    successMessage: "Wir benachrichtigen Sie, sobald Vermietler startet.",
    errorMessage: "Etwas ist schiefgelaufen. Bitte versuchen Sie es erneut.",
    featuresHeadline: "Was kommt",
    features: [
      { icon: "building", title: "Immobilien- & Einheitenverwaltung", description: "Organisieren Sie Ihr gesamtes Portfolio übersichtlich." },
      { icon: "bank", title: "Banking & Mietverfolgung", description: "Transaktionen automatisch importieren und Zahlungen abgleichen." },
      { icon: "receipt", title: "KI-Belegerfassung", description: "Beleg fotografieren — KI extrahiert Lieferant, Betrag und Kategorie." },
      { icon: "statement", title: "Nebenkostenabrechnung", description: "Abrechnungen per Assistent erstellen — inklusive PDF-Export." },
      { icon: "folder", title: "Dokumenten-Tresor", description: "Dokumente hochladen, taggen und sicher mit Mietern teilen." },
      { icon: "shield", title: "DSGVO-konform", description: "Von Anfang an nach deutschem Datenschutzrecht entwickelt." },
    ],
    legal: "Rechtliches",
    privacy: "Datenschutz",
    terms: "AGB",
    imprint: "Impressum",
    social: "Verbinden",
    loanCalc: "Tilgungsrechner",
    loanCalcHref: "/de/tilgungsrechner",
    copyright: `© ${new Date().getFullYear()} Vermietler. Alle Rechte vorbehalten.`,
  },
}[lang]!;

const iconPaths: Record<string, string> = {
  building: "M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z",
  bank: "M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z",
  receipt: "M9 14.25l6-6m4.5-3.493V21.75l-3.75-1.5-3.75 1.5-3.75-1.5-3.75 1.5V4.757c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0 1 11.186 0c1.1.128 1.907 1.077 1.907 2.185zM9.75 9h.008v.008H9.75V9zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0zm4.125 4.5h.008v.008h-.008V13.5zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0z",
  statement: "M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9z",
  folder: "M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44z",
  shield: "M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z",
};
---

<div class="min-h-screen flex flex-col bg-white">
  <!-- Hero -->
  <section class="relative flex-1 flex items-center overflow-hidden pt-24 pb-20 lg:pt-36 lg:pb-32">
    <!-- Background image -->
    <div class="absolute inset-0 z-0">
      <img src="/images/hero-bg.jpg" alt="" class="h-full w-full object-cover object-center" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-b from-gray-900/80 via-gray-900/70 to-gray-900/90"></div>
    </div>

    <!-- Decorative gradient orb -->
    <div class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
      <div class="absolute -top-40 left-1/2 h-[600px] w-[800px] -translate-x-1/2 rounded-full bg-brand-500/20 blur-[120px]"></div>
    </div>

    <div class="relative z-10 mx-auto w-full max-w-3xl px-6 text-center">
      <!-- Badge -->
      <div class="coming-soon-animate mb-8 inline-flex items-center gap-2 rounded-full border border-brand-400/30 bg-brand-500/10 backdrop-blur-sm px-4 py-1.5 text-sm font-medium text-brand-200">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-400"></span>
        </span>
        {t.badge}
      </div>

      <!-- Headline -->
      <h1 class="coming-soon-animate font-display text-5xl font-bold tracking-tight text-white sm:text-6xl lg:text-7xl" style="animation-delay: 0.1s">
        {t.headline}
        <br />
        <span class="bg-gradient-to-r from-brand-300 to-brand-400 bg-clip-text text-transparent">
          {t.headlineAccent}
        </span>
      </h1>

      <!-- Description -->
      <p class="coming-soon-animate mx-auto mt-6 max-w-xl text-lg leading-relaxed text-gray-300 sm:text-xl" style="animation-delay: 0.2s">
        {t.sub}
      </p>

      <!-- Email form -->
      <div class="coming-soon-animate mt-10 mx-auto max-w-lg rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md p-6" style="animation-delay: 0.3s">
        <form id="email-form" class="flex flex-col gap-3 sm:flex-row">
          <input
            type="email"
            id="email-input"
            required
            placeholder={t.emailPlaceholder}
            class="flex-1 rounded-xl border border-gray-200 bg-white px-5 py-3.5 text-base text-gray-900 shadow-xs outline-none transition placeholder:text-gray-400 focus:border-brand-400 focus:ring-4 focus:ring-brand-500/20"
          />
          <button
            type="submit"
            id="submit-btn"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-brand-500 px-7 py-3.5 text-base font-semibold text-white shadow-md transition hover:bg-brand-600 hover:shadow-lg disabled:opacity-60 disabled:cursor-not-allowed"
          >
            <span id="btn-text">{t.cta}</span>
            <svg id="btn-arrow" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
            <svg id="btn-spinner" class="hidden h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>
        </form>

        <!-- Success message -->
        <div id="success-msg" class="hidden rounded-xl border border-green-200 bg-green-50 p-5 text-center">
          <svg class="mx-auto h-8 w-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" />
          </svg>
          <p class="mt-2 text-base font-semibold text-green-800">{t.successTitle}</p>
          <p class="mt-1 text-sm text-green-600">{t.successMessage}</p>
        </div>

        <!-- Error message -->
        <div id="error-msg" class="hidden mt-3 rounded-lg bg-red-50 border border-red-200 px-4 py-2.5 text-sm text-red-700">
          {t.errorMessage}
        </div>
      </div>
    </div>
  </section>

  <!-- Feature highlights -->
  <section class="border-t border-gray-100 bg-gray-50 py-20">
    <div class="mx-auto max-w-5xl px-6">
      <p class="coming-soon-animate text-center text-xs font-semibold uppercase tracking-[0.08em] text-brand-500">{t.featuresHeadline}</p>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {t.features.map((feature, i) => (
          <div class="coming-soon-animate group flex items-start gap-4 rounded-2xl border border-gray-200 bg-white p-5 shadow-xs transition hover:border-brand-200 hover:shadow-md" style={`animation-delay: ${0.1 * i}s`}>
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-500 transition group-hover:bg-brand-100">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[feature.icon]} />
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-gray-900">{feature.title}</h3>
              <p class="mt-1 text-sm leading-relaxed text-gray-500">{feature.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-gray-200 bg-white py-12">
    <div class="mx-auto max-w-5xl px-6">
      <div class="flex flex-col items-center gap-8 sm:flex-row sm:items-start sm:justify-between">
        <!-- Brand -->
        <div class="text-center sm:text-left">
          <a href="/">
            <img src="/images/logo-compact.svg" alt="Vermietler" class="h-8" />
          </a>
          <p class="mt-2 text-sm text-gray-400">{t.badge}</p>
        </div>

        <!-- Links -->
        <div class="flex flex-wrap justify-center gap-x-10 gap-y-6 text-sm">
          <!-- Legal -->
          <div>
            <h4 class="font-semibold text-gray-900">{t.legal}</h4>
            <ul class="mt-3 space-y-2">
              <li><a href="#" class="text-gray-500 transition hover:text-gray-900">{t.imprint}</a></li>
              <li><a href="#" class="text-gray-500 transition hover:text-gray-900">{t.privacy}</a></li>
              <li><a href="#" class="text-gray-500 transition hover:text-gray-900">{t.terms}</a></li>
            </ul>
          </div>

          <!-- Social -->
          <div>
            <h4 class="font-semibold text-gray-900">{t.social}</h4>
            <ul class="mt-3 space-y-2">
              <li>
                <a href="#" class="inline-flex items-center gap-1.5 text-gray-500 transition hover:text-gray-900">
                  <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  LinkedIn
                </a>
              </li>
              <li>
                <a href="#" class="inline-flex items-center gap-1.5 text-gray-500 transition hover:text-gray-900">
                  <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  Twitter / X
                </a>
              </li>
              <li>
                <a href={t.loanCalcHref} class="inline-flex items-center gap-1.5 text-gray-500 transition hover:text-gray-900">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V18zm2.498-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 0 0 2.25 2.25h10.5a2.25 2.25 0 0 0 2.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0 0 12 2.25z" /></svg>
                  {t.loanCalc}
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <div class="mt-10 border-t border-gray-200 pt-6">
        <p class="text-center text-sm text-gray-400">{t.copyright}</p>
      </div>
    </div>
  </footer>
</div>

<style>
  @keyframes coming-soon-fade-up {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .coming-soon-animate {
    opacity: 0;
    animation: coming-soon-fade-up 0.7s ease-out forwards;
  }
</style>

<script define:vars={{ formEndpoint: "https://docs.google.com/forms/d/e/1FAIpQLScHcJlWZRXDs6RbxRDc44HUVVKgBSZWBQs-H28g7nWetaWpRQ/formResponse", entryId: "entry.741940622" }}>
  // ── Google Form POST Configuration ──
  // Replace these two values with your real Google Form endpoint and entry ID:
  const FORM_ENDPOINT = formEndpoint;
  const ENTRY_ID = entryId;

  const form = document.getElementById("email-form");
  const input = document.getElementById("email-input");
  const btn = document.getElementById("submit-btn");
  const btnText = document.getElementById("btn-text");
  const btnArrow = document.getElementById("btn-arrow");
  const spinner = document.getElementById("btn-spinner");
  const successMsg = document.getElementById("success-msg");
  const errorMsg = document.getElementById("error-msg");

  if (form && input && btn && btnText && btnArrow && spinner && successMsg && errorMsg) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = input.value.trim();
      if (!email) return;

      // Disable button, show spinner
      btn.disabled = true;
      btnText.classList.add("hidden");
      btnArrow.classList.add("hidden");
      spinner.classList.remove("hidden");
      errorMsg.classList.add("hidden");

      try {
        const body = new URLSearchParams();
        body.append(ENTRY_ID, email);

        await fetch(FORM_ENDPOINT, {
          method: "POST",
          mode: "no-cors",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: body.toString(),
        });

        // no-cors: fetch resolving = success (response is opaque)
        form.classList.add("hidden");
        successMsg.classList.remove("hidden");
      } catch {
        // Network error
        errorMsg.classList.remove("hidden");
        btn.disabled = false;
        btnText.classList.remove("hidden");
        btnArrow.classList.remove("hidden");
        spinner.classList.add("hidden");
      }
    });
  }
</script>
