---
interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;

const t = {
  en: {
    tagline: "Property management, simplified.",
    calculators: "Calculators",
    mortgageCalc: "Mortgage Calculator",
    mortgageCalcHref: "/hypothekenrechner",
    closingCostCalc: "Closing Cost Calculator",
    closingCostCalcHref: "/closing-cost-calculator",
    yieldCalc: "Rental Yield Calculator",
    yieldCalcHref: "/rental-yield-calculator",
    afaCalc: "AfA Calculator",
    afaCalcHref: "/afa-calculator",
    resources: "Resources",
    blog: "Blog",
    blogHref: "/blog",
    legal: "Legal",
    privacy: "Privacy policy",
    privacyHref: "/privacy",
    terms: "Terms of service",
    imprint: "Imprint",
    imprintHref: "/imprint",
    copyright: `\u00A9 ${new Date().getFullYear()} Vermietler. All rights reserved.`,
  },
  de: {
    tagline: "Immobilienverwaltung, vereinfacht.",
    calculators: "Rechner",
    mortgageCalc: "Tilgungsrechner",
    mortgageCalcHref: "/de/tilgungsrechner",
    closingCostCalc: "Kaufnebenkostenrechner",
    closingCostCalcHref: "/de/kaufnebenkostenrechner",
    yieldCalc: "Mietrenditerechner",
    yieldCalcHref: "/de/mietrenditerechner",
    afaCalc: "AfA-Rechner",
    afaCalcHref: "/de/afa-rechner",
    resources: "Ressourcen",
    blog: "Blog",
    blogHref: "/de/blog",
    legal: "Rechtliches",
    privacy: "Datenschutz",
    privacyHref: "/de/datenschutz",
    terms: "AGB",
    imprint: "Impressum",
    imprintHref: "/de/impressum",
    copyright: `\u00A9 ${new Date().getFullYear()} Vermietler. Alle Rechte vorbehalten.`,
  },
}[lang]!;
---

<footer class="border-t border-gray-200 bg-white py-16">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-5">
      <!-- Brand -->
      <div class="sm:col-span-2">
        <span class="flex items-center gap-2 font-display text-xl font-bold tracking-tight text-slate-800">
          <svg class="h-5 w-5 flex-shrink-0 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          <span>vermiet<span class="text-blue-600">ler</span></span>
        </span>
        <p class="mt-3 max-w-xs text-sm text-gray-500">{t.tagline}</p>
      </div>

      <!-- Calculators -->
      <div>
        <h4 class="text-sm font-semibold text-gray-900">{t.calculators}</h4>
        <ul class="mt-4 space-y-3">
          <li><a href={t.mortgageCalcHref} class="text-sm text-gray-500 transition hover:text-gray-900">{t.mortgageCalc}</a></li>
          <li><a href={t.closingCostCalcHref} class="text-sm text-gray-500 transition hover:text-gray-900">{t.closingCostCalc}</a></li>
          <li><a href={t.yieldCalcHref} class="text-sm text-gray-500 transition hover:text-gray-900">{t.yieldCalc}</a></li>
          <li><a href={t.afaCalcHref} class="text-sm text-gray-500 transition hover:text-gray-900">{t.afaCalc}</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-sm font-semibold text-gray-900">{t.resources}</h4>
        <ul class="mt-4 space-y-3">
          <li><a href={t.blogHref} class="text-sm text-gray-500 transition hover:text-gray-900">{t.blog}</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-semibold text-gray-900">{t.legal}</h4>
        <ul class="mt-4 space-y-3">
          <li><a href={t.privacyHref} class="text-sm text-gray-500 transition hover:text-gray-900">{t.privacy}</a></li>
          <li><a href="#" class="text-sm text-gray-500 transition hover:text-gray-900">{t.terms}</a></li>
          <li><a href={t.imprintHref} class="text-sm text-gray-500 transition hover:text-gray-900">{t.imprint}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center gap-3 border-t border-gray-200 pt-8 sm:flex-row sm:justify-between">
      <p class="text-sm text-gray-400">{t.copyright}</p>
      <a href="mailto:info@vermietler.com" class="inline-flex items-center gap-1.5 text-sm text-gray-400 transition hover:text-gray-700">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        info@vermietler.com
      </a>
    </div>
  </div>
</footer>
