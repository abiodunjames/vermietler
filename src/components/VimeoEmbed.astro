---
interface Props {
  videoId: string;
  title?: string;
  /** Optional override for the poster image URL. If not set, the Vimeo thumbnail is fetched at build time. */
  poster?: string;
  /** Aspect ratio class. Defaults to 16:9 */
  aspect?: string;
  lang?: string;
}

const { videoId, title = "Video", poster, aspect = "aspect-video", lang = "en" } = Astro.props;

const playLabel = lang === "de" ? "Video abspielen" : "Play video";
const consentLabel = lang === "de"
  ? "Mit dem Klick laden Sie den Vimeo-Player. Dabei werden Daten an Vimeo übertragen."
  : "Clicking loads the Vimeo player. Data will be transferred to Vimeo.";

const uniqueId = `vimeo-${videoId}-${Math.random().toString(36).slice(2, 8)}`;

// Fetch the Vimeo thumbnail at build time via the public oEmbed endpoint.
// Falls back to the brand gradient if the lookup fails (e.g. private video, no network).
let thumbnailUrl: string | null = poster ?? null;
if (!thumbnailUrl) {
  try {
    const res = await fetch(
      `https://vimeo.com/api/oembed.json?url=https://vimeo.com/${videoId}&width=1280`,
      { signal: AbortSignal.timeout(5000) }
    );
    if (res.ok) {
      const data = await res.json();
      // Prefer the largest variant by stripping size suffix and requesting 1280px wide.
      if (data.thumbnail_url) {
        thumbnailUrl = data.thumbnail_url.replace(/_\d+x\d+(\.\w+)?$/, "_1280$1");
      }
    }
  } catch (e) {
    // Silently fall back to gradient placeholder
  }
}
---

<div
  id={uniqueId}
  class:list={["vimeo-embed group relative w-full overflow-hidden rounded-2xl bg-gray-900 shadow-2xl", aspect]}
  data-video-id={videoId}
  data-title={title}
>
  {/* Poster / placeholder */}
  <button
    type="button"
    class="vimeo-poster absolute inset-0 flex h-full w-full cursor-pointer items-center justify-center transition hover:brightness-110"
    style={thumbnailUrl ? `background-image:url(${thumbnailUrl});background-size:cover;background-position:center;` : "background:linear-gradient(135deg,#1e2d45 0%,#1d4ed8 100%);"}
    aria-label={playLabel}
  >
    {/* Dark gradient overlay for play button contrast */}
    {thumbnailUrl && (
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/50 via-black/10 to-transparent"></div>
    )}

    {/* Subtle pattern overlay (only on gradient fallback) */}
    {!thumbnailUrl && (
      <div class="pointer-events-none absolute inset-0 opacity-[0.06]" style="background-image:url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E&quot;);background-repeat:repeat;"></div>
    )}

    {/* Play button */}
    <div class="relative flex flex-col items-center gap-3">
      <div class="flex h-16 w-16 items-center justify-center rounded-full bg-white/95 shadow-xl transition group-hover:scale-110 sm:h-20 sm:w-20">
        <svg class="ml-1 h-6 w-6 text-brand-600 sm:h-7 sm:w-7" viewBox="0 0 24 24" fill="currentColor">
          <path d="M8 5v14l11-7z" />
        </svg>
      </div>
      <span class="text-xs font-medium text-white drop-shadow sm:text-sm">{playLabel}</span>
    </div>
  </button>

  {/* DSGVO consent note */}
  <div class="vimeo-consent pointer-events-none absolute bottom-3 left-3 right-3 text-center text-[10px] text-white/40 sm:text-[11px]">
    {consentLabel}
  </div>
</div>

<script define:vars={{ uniqueId, videoId, title }}>
  (function(){
    var container = document.getElementById(uniqueId);
    if (!container) return;
    var poster = container.querySelector('.vimeo-poster');
    var consent = container.querySelector('.vimeo-consent');
    if (!poster) return;
    poster.addEventListener('click', function() {
      var iframe = document.createElement('iframe');
      iframe.src = 'https://player.vimeo.com/video/' + videoId + '?autoplay=1&title=0&byline=0&portrait=0&dnt=1';
      iframe.title = title;
      iframe.allow = 'autoplay; fullscreen; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';
      poster.replaceWith(iframe);
      if (consent) consent.remove();
    });
  })();
</script>
