---
interface Props {
  lang?: string;
  variant?: "default" | "transparent";
}

const { lang = "en", variant = "default" } = Astro.props;
const isTransparent = variant === "transparent";

const t = {
  en: {
    home: "Home",
    homeHref: "/",
    blog: "Blog",
    blogHref: "/blog",
    mortgageCalc: "Mortgage Calculator",
    mortgageCalcHref: "/hypothekenrechner",
    closingCostCalc: "Closing Cost Calculator",
    closingCostCalcHref: "/closing-cost-calculator",
    yieldCalc: "Yield Calculator",
    yieldCalcHref: "/rental-yield-calculator",
    afaCalc: "AfA Calculator",
    afaCalcHref: "/afa-calculator",
    getStarted: "Get early access",
    langSwitch: "DE",
    langHref: "/de",
  },
  de: {
    home: "Startseite",
    homeHref: "/de",
    blog: "Blog",
    blogHref: "/de/blog",
    mortgageCalc: "Tilgungsrechner",
    mortgageCalcHref: "/de/tilgungsrechner",
    closingCostCalc: "Kaufnebenkostenrechner",
    closingCostCalcHref: "/de/kaufnebenkostenrechner",
    yieldCalc: "Mietrenditerechner",
    yieldCalcHref: "/de/mietrenditerechner",
    afaCalc: "AfA-Rechner",
    afaCalcHref: "/de/afa-rechner",
    getStarted: "Früher Zugang",
    langSwitch: "EN",
    langHref: "/",
  },
}[lang]!;
---

<nav
  class:list={[
    "fixed top-0 z-50 w-full transition-all duration-200",
    isTransparent ? "" : "border-b border-gray-200 bg-white/80 backdrop-blur-lg"
  ]}
  data-nav-variant={variant}
>
  <div class="mx-auto flex max-w-[1160px] items-center justify-between px-8 py-4">
    <a href={lang === "de" ? "/de" : "/"} class:list={["flex items-center gap-2 font-display text-xl font-bold tracking-tight no-underline transition", isTransparent ? "nav-logo-text text-white" : "text-slate-800"]}>
      <svg class:list={["h-5 w-5 flex-shrink-0", isTransparent ? "text-blue-400" : "text-blue-600"]} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <span>vermiet<span class:list={[isTransparent ? "text-blue-400" : "text-blue-600"]}>ler</span></span>
    </a>

    <div class="hidden items-center gap-2 md:flex">
      <a
        href={t.homeHref}
        class:list={[
          "rounded-md px-3 py-1.5 text-sm font-medium transition",
          isTransparent
            ? "nav-link-text"
            : "text-gray-500 hover:text-gray-900 hover:bg-gray-100"
        ]}
      >
        {t.home}
      </a>

      <!-- Calculators dropdown -->
      <div class="nav-dropdown relative">
        <button
          type="button"
          class:list={[
            "flex items-center gap-1 rounded-md px-3 py-1.5 text-sm font-medium transition",
            isTransparent
              ? "nav-link-text"
              : "text-gray-500 hover:text-gray-900 hover:bg-gray-100"
          ]}
        >
          {lang === "de" ? "Rechner" : "Calculators"}
          <svg class="h-3.5 w-3.5 opacity-60 transition-transform duration-200 nav-chevron" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" /></svg>
        </button>
        <div class="nav-dropdown-menu invisible absolute left-0 top-full z-50 mt-1 min-w-[220px] rounded-xl border border-gray-200 bg-white py-1.5 opacity-0 shadow-lg transition-all duration-150">
          {[
            { href: t.mortgageCalcHref, label: t.mortgageCalc, icon: "M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V18zm2.498-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 0 0 2.25 2.25h10.5a2.25 2.25 0 0 0 2.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0 0 12 2.25z" },
            { href: t.closingCostCalcHref, label: t.closingCostCalc, icon: "M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" },
            { href: t.yieldCalcHref, label: t.yieldCalc, icon: "M2.25 18L9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" },
            { href: t.afaCalcHref, label: t.afaCalc, icon: "M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9z" },
          ].map(link => (
            <a
              href={link.href}
              class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-600 transition hover:bg-gray-50 hover:text-gray-900"
            >
              <svg class="h-4 w-4 shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d={link.icon} /></svg>
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <a
        href={t.blogHref}
        class:list={[
          "rounded-md px-3 py-1.5 text-sm font-medium transition",
          isTransparent
            ? "nav-link-text"
            : "text-gray-500 hover:text-gray-900 hover:bg-gray-100"
        ]}
      >
        {t.blog}
      </a>
    </div>

    <div class="flex items-center gap-2.5">
      <a
        href={t.langHref}
        class:list={[
          "rounded-full border px-4 py-1.5 text-sm font-semibold transition",
          isTransparent
            ? "nav-lang-text border-white/30 hover:bg-white/10 hover:border-white/50"
            : "border-gray-300 text-gray-700 hover:bg-gray-50"
        ]}
      >
        {t.langSwitch}
      </a>
      <a
        href={t.homeHref}
        class="rounded-full bg-brand-500 px-5 py-2 text-sm font-semibold text-white shadow-xs transition hover:bg-brand-600 hover:-translate-y-px hover:shadow-md"
      >
        {t.getStarted}
      </a>
    </div>
  </div>
</nav>

<style is:global>
  [data-nav-variant="transparent"] {
    background: transparent;
    border-bottom: 1px solid transparent;
  }
  [data-nav-variant="transparent"].scrolled {
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(14px);
    border-bottom-color: var(--color-gray-200);
    box-shadow: var(--shadow-sm);
  }
  [data-nav-variant="transparent"].scrolled .nav-logo-text {
    color: var(--color-gray-800);
  }
  [data-nav-variant="transparent"].scrolled .nav-logo-text svg,
  [data-nav-variant="transparent"].scrolled .nav-logo-text span {
    color: #2563eb;
  }
  [data-nav-variant="transparent"] .nav-link-text {
    color: rgba(255, 255, 255, 0.7);
  }
  [data-nav-variant="transparent"] .nav-link-text:hover {
    color: rgba(255, 255, 255, 0.95);
    background: rgba(255, 255, 255, 0.08);
  }
  [data-nav-variant="transparent"].scrolled .nav-link-text {
    color: var(--color-gray-600);
  }
  [data-nav-variant="transparent"].scrolled .nav-link-text:hover {
    color: var(--color-gray-900);
    background: var(--color-gray-100);
  }
  [data-nav-variant="transparent"] .nav-lang-text {
    color: rgba(255, 255, 255, 0.9);
  }
  [data-nav-variant="transparent"].scrolled .nav-lang-text {
    color: var(--color-gray-700);
    border-color: var(--color-gray-300);
  }
  [data-nav-variant="transparent"].scrolled .nav-lang-text:hover {
    background: var(--color-gray-50);
  }

  /* Dropdown */
  .nav-dropdown:hover .nav-dropdown-menu,
  .nav-dropdown:focus-within .nav-dropdown-menu {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
  }
  .nav-dropdown-menu {
    transform: translateY(-4px);
  }
  .nav-dropdown:hover .nav-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  const nav = document.querySelector('[data-nav-variant="transparent"]');
  if (nav) {
    const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 30);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
