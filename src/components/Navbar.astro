---
interface Props {
  lang?: string;
  variant?: "default" | "transparent";
}

const { lang = "en", variant = "default" } = Astro.props;
const isTransparent = variant === "transparent";

const t = {
  en: {
    home: "Home",
    homeHref: "/",
    blog: "Blog",
    blogHref: "/blog",
    mortgageCalc: "Mortgage Calculator",
    mortgageCalcHref: "/hypothekenrechner",
    closingCostCalc: "Closing Cost Calculator",
    closingCostCalcHref: "/closing-cost-calculator",
    getStarted: "Get early access",
    langSwitch: "DE",
    langHref: "/de",
  },
  de: {
    home: "Startseite",
    homeHref: "/de",
    blog: "Blog",
    blogHref: "/de/blog",
    mortgageCalc: "Tilgungsrechner",
    mortgageCalcHref: "/de/tilgungsrechner",
    closingCostCalc: "Kaufnebenkostenrechner",
    closingCostCalcHref: "/de/kaufnebenkostenrechner",
    getStarted: "Früher Zugang",
    langSwitch: "EN",
    langHref: "/",
  },
}[lang]!;
---

<nav
  class:list={[
    "fixed top-0 z-50 w-full transition-all duration-200",
    isTransparent ? "" : "border-b border-gray-200 bg-white/80 backdrop-blur-lg"
  ]}
  data-nav-variant={variant}
>
  <div class="mx-auto flex max-w-[1160px] items-center justify-between px-8 py-4">
    <a href={lang === "de" ? "/de" : "/"} class:list={["flex items-center gap-2 font-display text-xl font-bold tracking-tight no-underline transition", isTransparent ? "nav-logo-text text-white" : "text-slate-800"]}>
      <svg class:list={["h-5 w-5 flex-shrink-0", isTransparent ? "text-blue-400" : "text-blue-600"]} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <span>vermiet<span class:list={[isTransparent ? "text-blue-400" : "text-blue-600"]}>ler</span></span>
    </a>

    <div class="hidden items-center gap-2 md:flex">
      {[
        { href: t.homeHref, label: t.home },
        { href: t.blogHref, label: t.blog },
        { href: t.mortgageCalcHref, label: t.mortgageCalc },
        { href: t.closingCostCalcHref, label: t.closingCostCalc },
      ].map(link => (
        <a
          href={link.href}
          class:list={[
            "rounded-md px-3 py-1.5 text-sm font-medium transition",
            isTransparent
              ? "nav-link-text"
              : "text-gray-500 hover:text-gray-900 hover:bg-gray-100"
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-2.5">
      <a
        href={t.langHref}
        class:list={[
          "rounded-full border px-4 py-1.5 text-sm font-semibold transition",
          isTransparent
            ? "nav-lang-text border-white/30 hover:bg-white/10 hover:border-white/50"
            : "border-gray-300 text-gray-700 hover:bg-gray-50"
        ]}
      >
        {t.langSwitch}
      </a>
      <a
        href={t.homeHref}
        class="rounded-full bg-brand-500 px-5 py-2 text-sm font-semibold text-white shadow-xs transition hover:bg-brand-600 hover:-translate-y-px hover:shadow-md"
      >
        {t.getStarted}
      </a>
    </div>
  </div>
</nav>

<style is:global>
  [data-nav-variant="transparent"] {
    background: transparent;
    border-bottom: 1px solid transparent;
  }
  [data-nav-variant="transparent"].scrolled {
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(14px);
    border-bottom-color: var(--color-gray-200);
    box-shadow: var(--shadow-sm);
  }
  [data-nav-variant="transparent"].scrolled .nav-logo-text {
    color: var(--color-gray-800);
  }
  [data-nav-variant="transparent"].scrolled .nav-logo-text svg,
  [data-nav-variant="transparent"].scrolled .nav-logo-text span {
    color: #2563eb;
  }
  [data-nav-variant="transparent"] .nav-link-text {
    color: rgba(255, 255, 255, 0.7);
  }
  [data-nav-variant="transparent"] .nav-link-text:hover {
    color: rgba(255, 255, 255, 0.95);
    background: rgba(255, 255, 255, 0.08);
  }
  [data-nav-variant="transparent"].scrolled .nav-link-text {
    color: var(--color-gray-600);
  }
  [data-nav-variant="transparent"].scrolled .nav-link-text:hover {
    color: var(--color-gray-900);
    background: var(--color-gray-100);
  }
  [data-nav-variant="transparent"] .nav-lang-text {
    color: rgba(255, 255, 255, 0.9);
  }
  [data-nav-variant="transparent"].scrolled .nav-lang-text {
    color: var(--color-gray-700);
    border-color: var(--color-gray-300);
  }
  [data-nav-variant="transparent"].scrolled .nav-lang-text:hover {
    background: var(--color-gray-50);
  }
</style>

<script>
  const nav = document.querySelector('[data-nav-variant="transparent"]');
  if (nav) {
    const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 30);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
