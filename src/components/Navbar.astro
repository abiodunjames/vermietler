---
interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;

const t = {
  en: {
    home: "Home",
    homeHref: "/",
    blog: "Blog",
    blogHref: "/blog",
    mortgageCalc: "Mortgage Calculator",
    mortgageCalcHref: "/hypothekenrechner",
    closingCostCalc: "Closing Cost Calculator",
    closingCostCalcHref: "/closing-cost-calculator",
    getStarted: "Get early access",
    langSwitch: "DE",
    langHref: "/de",
  },
  de: {
    home: "Startseite",
    homeHref: "/de",
    blog: "Blog",
    blogHref: "/de/blog",
    mortgageCalc: "Tilgungsrechner",
    mortgageCalcHref: "/de/tilgungsrechner",
    closingCostCalc: "Kaufnebenkostenrechner",
    closingCostCalcHref: "/de/kaufnebenkostenrechner",
    getStarted: "Früher Zugang",
    langSwitch: "EN",
    langHref: "/",
  },
}[lang]!;
---

<nav class="fixed top-0 z-50 w-full border-b border-gray-200 bg-white/80 backdrop-blur-lg">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href={lang === "de" ? "/de" : "/"}>
      <img src="/images/logo-compact.svg" alt="Vermietler" class="h-7" />
    </a>

    <div class="hidden items-center gap-8 md:flex">
      <a href={t.homeHref} class="text-sm font-medium text-gray-500 transition hover:text-gray-900">
        {t.home}
      </a>
      <a href={t.blogHref} class="text-sm font-medium text-gray-500 transition hover:text-gray-900">
        {t.blog}
      </a>
      <a href={t.mortgageCalcHref} class="text-sm font-medium text-gray-500 transition hover:text-gray-900">
        {t.mortgageCalc}
      </a>
      <a href={t.closingCostCalcHref} class="text-sm font-medium text-gray-500 transition hover:text-gray-900">
        {t.closingCostCalc}
      </a>
    </div>

    <div class="flex items-center gap-3">
      <a
        href={t.langHref}
        class="rounded-lg px-3 py-1.5 text-sm font-medium text-gray-400 transition hover:bg-gray-100"
      >
        {t.langSwitch}
      </a>
      <a
        href={t.homeHref}
        class="rounded-lg bg-brand-500 px-5 py-2.5 text-sm font-semibold text-white shadow-xs transition hover:bg-brand-600"
      >
        {t.getStarted}
      </a>
    </div>
  </div>
</nav>
